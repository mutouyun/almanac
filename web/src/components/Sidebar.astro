---
// web/src/components/Sidebar.astro
const { activePage } = Astro.props;

const menuItems = [
  { name: '概览看板', icon: 'layout-dashboard', href: '/dashboard', id: 'dashboard' },
  { name: '账本明细', icon: 'book-text', href: '/ledger', id: 'ledger' },
  { name: '分类管理', icon: 'tags', href: '/categories', id: 'categories' },
];
---

<aside 
  id="sidebar"
  class="w-64 bg-white border-r border-slate-200 flex flex-col fixed h-full z-20 transition-transform duration-300 ease-in-out"
>
  <!-- Collapse Toggle Button (Floating) -->
  <button 
    id="sidebar-toggle" 
    class="absolute -right-3 top-9 w-6 h-6 bg-white border border-slate-200 rounded-full flex items-center justify-center text-slate-400 hover:text-blue-600 shadow-sm z-30 transition-all"
  >
    <i data-lucide="chevron-left" id="toggle-icon" class="w-4 h-4 transition-transform duration-300"></i>
  </button>

  <div class="p-6">
    <div class="flex items-center gap-3 text-blue-600">
      <i data-lucide="book-open" class="w-8 h-8"></i>
      <span class="text-xl font-bold tracking-tight text-slate-800">Almanac</span>
    </div>
  </div>
  
  <nav class="flex-1 px-4 space-y-1">
    {menuItems.map((item) => (
      <a 
        href={item.href} 
        class={`flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all ${
          activePage === item.id 
            ? 'bg-blue-50 text-blue-600' 
            : 'text-slate-600 hover:bg-slate-50'
        }`}
      >
        <i data-lucide={item.icon} class="w-5 h-5"></i>
        <span>{item.name}</span>
      </a>
    ))}
    <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 cursor-not-allowed font-medium transition-all">
      <i data-lucide="bar-chart-3" class="w-5 h-5"></i>
      <span>统计报表</span>
      <span class="text-[10px] bg-slate-100 px-1.5 py-0.5 rounded text-slate-500 ml-auto">TBD</span>
    </a>
    <a
      id="sidebar-admin-link"
      href="/admin/users"
      style="display: none;"
      class={`flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all ${
        activePage === 'users'
          ? 'bg-blue-50 text-blue-600'
          : 'text-slate-600 hover:bg-slate-50'
      }`}
    >
      <i data-lucide="users" class="w-5 h-5"></i>
      <span>账户管理</span>
    </a>
  </nav>

  <div class="p-4 border-t border-slate-100">
    <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-slate-50">
      <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-sm" id="sidebar-user-avatar">
        ?
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold truncate" id="sidebar-user-name">Loading...</p>
        <p class="text-xs text-slate-400 truncate" id="sidebar-user-role">...</p>
      </div>
      <button id="sidebar-logout-btn" class="text-slate-400 hover:text-rose-500 transition-colors">
        <i data-lucide="log-out" class="w-4 h-4"></i>
      </button>
    </div>
  </div>
</aside>

<script>
  // Shared logic for the sidebar across all pages
  function initSidebar() {
    const avatar = document.getElementById('sidebar-user-avatar');
    const name = document.getElementById('sidebar-user-name');
    const role = document.getElementById('sidebar-user-role');
    const logoutBtn = document.getElementById('sidebar-logout-btn');

    if (!avatar || !name || !role) return;

    fetch('/api/whoami')
      .then(r => r.json())
      .then(d => {
        name.textContent = d.username;
        role.textContent = d.is_admin ? '超级管理员' : '普通用户';
        avatar.textContent = d.username[0].toUpperCase();
        const adminLink = document.getElementById('sidebar-admin-link');
        if (adminLink) adminLink.style.display = d.is_admin ? 'flex' : 'none';
      })
      .catch(() => {
        if (window.location.pathname !== '/login') window.location.href = '/login';
      });

    if (logoutBtn) {
      logoutBtn.onclick = async () => {
        await fetch('/api/logout', { method: 'POST' });
        window.location.href = '/login';
      };
    }
  }

  // Support both normal load and Astro View Transitions
  window.lucide?.createIcons();
  initSidebar();

  function initToggle() {
    const sidebar = document.getElementById('sidebar');
    const toggle = document.getElementById('sidebar-toggle');
    const icon = document.getElementById('toggle-icon');
    const main = document.querySelector('main');
    
    if (!sidebar || !toggle || !main) return;

    let collapsed = localStorage.getItem('sidebar-collapsed') === 'true';

    const updateUI = () => {
      if (collapsed) {
        sidebar.style.transform = 'translateX(-100%)';
        main.style.marginLeft = '0';
        if (icon) icon.style.transform = 'rotate(180deg)';
        toggle.style.right = '-40px'; // Pop out more when collapsed
      } else {
        sidebar.style.transform = 'translateX(0)';
        main.style.marginLeft = '16rem'; // 64 * 0.25rem
        if (icon) icon.style.transform = 'rotate(0deg)';
        toggle.style.right = '-12px'; // Default position
      }
    };

    toggle.onclick = () => {
      collapsed = !collapsed;
      localStorage.setItem('sidebar-collapsed', collapsed);
      updateUI();
    };

    // Apply initial state without transition for first load
    sidebar.classList.remove('transition-transform');
    main.classList.remove('transition-[margin]');
    updateUI();
    // Force reflow
    sidebar.offsetHeight;
    sidebar.classList.add('transition-transform');
    main.classList.add('transition-[margin]');
    main.classList.add('duration-300');
  }

  initToggle();
  document.addEventListener('astro:after-swap', () => {
    window.lucide?.createIcons();
    initSidebar();
    initToggle();
  });
</script>
