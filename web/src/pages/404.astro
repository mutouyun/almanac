---
// src/pages/404.astro
const title = '页面未找到 · Almanac';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lucide-static@0.400.0/font/lucide.min.css" />
    <style>
      @font-face {
        font-family: 'Geist';
        src: url('https://cdn.jsdelivr.net/gh/vercel/geist-font@1.0.0/fonts/geist-sans/Geist-Regular.woff2') format('woff2');
      }
      body { font-family: 'Geist', system-ui, -apple-system, sans-serif; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen flex items-center justify-center p-6">
    <div class="max-w-md w-full text-center">
      <div class="mb-8 inline-flex p-6 bg-white rounded-3xl shadow-sm border border-slate-100 relative">
        <i class="lucide-ghost w-16 h-16 text-blue-500 animate-bounce"></i>
        <div class="absolute -top-2 -right-2 bg-rose-500 text-white text-[10px] font-bold px-2 py-1 rounded-full shadow-lg shadow-rose-200">
          404 ERROR
        </div>
      </div>
      
      <h1 class="text-4xl font-bold text-slate-800 tracking-tight mb-4">迷路了吗？</h1>
      <p class="text-slate-500 mb-10 leading-relaxed">
        您访问的页面似乎已经漂流到了未知的数字海洋中。<br/>
        没关系，每一笔账单都有它的归宿，您也一样。
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/dashboard" class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl shadow-lg shadow-blue-100 transition-all transform active:scale-[0.98] flex items-center justify-center gap-2">
          <i class="lucide-home w-4 h-4"></i>
          回到看板
        </a>
        <button onclick="history.back()" class="px-8 py-3 bg-white hover:bg-slate-50 text-slate-600 font-bold rounded-2xl border border-slate-200 transition-all flex items-center justify-center gap-2">
          <i class="lucide-arrow-left w-4 h-4"></i>
          返回上一页
        </button>
      </div>

      <p class="mt-12 text-slate-300 text-xs font-medium uppercase tracking-widest">
        Almanac Ledger System
      </p>
    </div>
  </body>
</html>
