---
// Almanac Categories 2.0 - Visual Overhaul
import Sidebar from '../components/Sidebar.astro';
const title = '分类管理 · Almanac';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline src="https://cdn.jsdelivr.net/npm/lucide@0.400.0/dist/umd/lucide.min.js"></script>
    <style>
      @font-face {
        font-family: 'Geist';
        src: url('https://cdn.jsdelivr.net/gh/vercel/geist-font@1.0.0/fonts/geist-sans/Geist-Regular.woff2') format('woff2');
      }
      body { font-family: 'Geist', system-ui, -apple-system, sans-serif; }
      .glass {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }
      dialog::backdrop { background: rgba(15, 23, 42, 0.5); backdrop-filter: blur(4px); }
      /* Custom Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen flex">
    <!-- Sidebar -->
    <Sidebar activePage="categories" />

    <!-- Main Content -->
    <main class="flex-1 ml-64 p-8 max-w-5xl">
      <header class="flex justify-between items-end mb-8">
        <div>
          <h1 class="text-3xl font-bold text-slate-800 tracking-tight">分类管理 🗂️</h1>
          <p class="text-slate-500 mt-1">管理您的收支架构，让每一分钱都有迹可循。</p>
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Category Tree -->
        <div class="lg:col-span-2 space-y-6">
          <section class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center gap-2 font-bold text-slate-800">
              <i data-lucide="git-merge" class="text-blue-500 w-5 h-5"></i>
              分类结构树
            </div>
            
            <div id="tree-loading" class="p-12 text-center text-slate-400">
              <div class="animate-pulse flex flex-col items-center">
                <div class="h-8 w-8 bg-slate-100 rounded-full mb-3"></div>
                <div class="h-2 w-24 bg-slate-100 rounded"></div>
              </div>
            </div>

            <div id="tree" class="divide-y divide-slate-50 min-h-[200px]" hidden></div>
            <div id="tree-empty" class="p-12 text-center text-slate-400 text-sm" hidden>暂无分类数据</div>
          </section>
        </div>

        <!-- Add Category Form -->
        <div class="space-y-6">
          <section class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm sticky top-8">
            <h3 class="font-bold text-slate-800 mb-6 flex items-center gap-2">
              <i data-lucide="plus-circle" class="text-emerald-500 w-5 h-5"></i>
              新增分类
            </h3>
            <form id="add-form" class="space-y-4">
              <div class="space-y-1">
                <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">分类名称</label>
                <input id="c-name" type="text" required placeholder="如：餐饮、工资" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:outline-none focus:border-blue-300 transition-all" />
              </div>

              <div class="space-y-1">
                <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">父级分类</label>
                <select id="c-parent" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:border-blue-300 transition-all"></select>
              </div>

              <div id="dir-wrap" class="space-y-1">
                <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">收支方向</label>
                <select id="c-dir" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:border-blue-300 transition-all text-slate-600 font-medium">
                  <option value="-1">支出 (-)</option>
                  <option value="1">收入 (+)</option>
                </select>
              </div>

              <div class="space-y-1">
                <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">正则匹配 (可选)</label>
                <input id="c-regex" type="text" placeholder="如：瑞幸|星巴克" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-100 rounded-xl text-sm font-mono focus:outline-none focus:border-blue-300 transition-all" />
              </div>

              <button type="submit" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl shadow-lg shadow-blue-100 transition-all transform active:scale-[0.98]">
                提交创建
              </button>
              <p id="add-msg" class="text-center text-[11px] min-h-[1em]"></p>
            </form>
          </section>
        </div>
      </div>
    </main>

    <!-- Edit Dialog (Modernized) -->
    <dialog id="edit-dialog" class="bg-white rounded-3xl p-8 shadow-2xl max-w-sm w-full border border-slate-100">
        <h3 class="text-xl font-bold text-slate-800 mb-6">编辑分类信息</h3>
        <input type="hidden" id="e-id" />
        <div class="space-y-4">
            <div class="space-y-1">
                <label class="text-[11px] font-bold text-slate-400 uppercase">名称</label>
                <input id="e-name" type="text" class="w-full px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:border-blue-300" />
            </div>
            <div class="space-y-1">
                <label class="text-[11px] font-bold text-slate-400 uppercase">正则匹配</label>
                <input id="e-regex" type="text" class="w-full px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl text-sm font-mono outline-none focus:border-blue-300" />
            </div>
            <div class="space-y-1">
                <label class="text-[11px] font-bold text-slate-400 uppercase">移动至父分类</label>
                <select id="e-parent" class="w-full px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:border-blue-300"></select>
            </div>
            <p id="edit-msg" class="text-center text-[11px] min-h-[1em]"></p>
            <div class="flex gap-3 mt-4">
                <button id="edit-cancel" class="flex-1 py-2 text-slate-400 font-bold hover:bg-slate-50 rounded-xl transition-all">取消</button>
                <button id="edit-save" class="flex-1 py-2 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-all shadow-lg shadow-blue-100">保存修改</button>
            </div>
        </div>
    </dialog>

    <script>
      let categories = [];

      fetch('/api/whoami')
        .then(r => r.json())
        .then(d => {
          loadCategories();
        }).catch(() => window.location.href = '/login');

      async function loadCategories() {
        const res = await fetch('/api/categories');
        const data = await res.json();
        categories = data.categories || [];
        renderTree();
        updateParentSelect();
      }

      function renderTree() {
        const tree = document.getElementById('tree');
        const empty = document.getElementById('tree-empty');
        const loading = document.getElementById('tree-loading');
        loading.hidden = true;
        
        if (categories.length === 0) {
          tree.hidden = true;
          empty.hidden = false;
          return;
        }

        const childrenOf = new Map();
        categories.forEach(c => {
          const key = c.parent_id || 0;
          if (!childrenOf.has(key)) childrenOf.set(key, []);
          childrenOf.get(key).push(c);
        });
        childrenOf.forEach(list => list.sort((a, b) => a.sort_order - b.sort_order || a.id - b.id));

        const rows = [];
        const walk = (p, d) => {
          (childrenOf.get(p) || []).forEach(c => {
            const indent = d * 1.5;
            const isInc = c.direction === 1;
            const badgeClass = isInc ? 'bg-emerald-50 text-emerald-600' : 'bg-rose-50 text-rose-600';
            
            rows.push(`
              <div class="px-6 py-3 flex items-center hover:bg-slate-50 transition-colors group" style="padding-left: ${indent + 1.5}rem">
                <div class="flex items-center gap-3 flex-1 min-w-0">
                  ${d > 0 ? '<span class="text-slate-300 font-light select-none">└─</span>' : ''}
                  <span class="font-bold text-slate-700">${c.name}</span>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded ${badgeClass}">${isInc ? '收入' : '支出'}</span>
                  ${c.regex ? `<span class="text-[11px] font-mono text-slate-400 bg-slate-50 px-2 py-0.5 rounded border border-slate-100 truncate max-w-[150px]">${c.regex}</span>` : ''}
                </div>
                <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                  <button onclick="editCategory(${c.id})" class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all">
                    <i data-lucide="pencil" class="w-4 h-4"></i>
                  </button>
                  <button onclick="deleteCategory(${c.id})" class="p-1.5 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition-all">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                  </button>
                </div>
              </div>
            `);
            walk(c.id, d + 1);
          });
        };
        walk(0, 0);
        tree.innerHTML = rows.join('');
        window.lucide?.createIcons();
        tree.hidden = false;
        empty.hidden = true;
      }

      function updateParentSelect() {
        const sel = document.getElementById('c-parent');
        const childrenOf = new Map();
        categories.forEach(c => {
          const key = c.parent_id || 0;
          if (!childrenOf.has(key)) childrenOf.set(key, []);
          childrenOf.get(key).push(c);
        });
        const ordered = [];
        const walk = (p) => { (childrenOf.get(p) || []).forEach(c => { ordered.push(c); walk(c.id); }); };
        walk(0);
        
        sel.innerHTML = '<option value="">(无，作为根分类)</option>' +
          ordered.map(c => {
            const indent = c.level > 1 ? '\u3000'.repeat(c.level - 1) + '└ ' : '';
            return `<option value="${c.id}">${indent}${c.name}</option>`;
          }).join('');
      }

      document.getElementById('c-parent').onchange = (e) => {
        document.getElementById('dir-wrap').hidden = e.target.value !== '';
      };

      document.getElementById('add-form').onsubmit = async (e) => {
        e.preventDefault();
        const msg = document.getElementById('add-msg');
        const parentId = e.target['c-parent'].value ? Number(e.target['c-parent'].value) : null;
        const body = {
          name: e.target['c-name'].value,
          parent_id: parentId,
          direction: parentId ? 0 : Number(e.target['c-dir'].value),
          regex: e.target['c-regex'].value,
          sort_order: 0
        };
        const res = await fetch('/api/categories', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (res.ok) {
          msg.className = 'text-center text-[11px] text-emerald-500';
          msg.textContent = '✅ 创建成功';
          e.target.reset();
          document.getElementById('dir-wrap').hidden = false;
          loadCategories();
        } else {
          const d = await res.json();
          msg.className = 'text-center text-[11px] text-rose-500';
          msg.textContent = '❌ ' + (d.error || '创建失败');
        }
      };

      window.editCategory = function(id) {
        const c = categories.find(x => x.id === id);
        if (!c) return;
        const dialog = document.getElementById('edit-dialog');
        document.getElementById('e-id').value = c.id;
        document.getElementById('e-name').value = c.name;
        document.getElementById('e-regex').value = c.regex || '';
        
        const forbidden = new Set([id]);
        const walkForbid = (pid) => {
            categories.filter(x => x.parent_id === pid).forEach(x => { forbidden.add(x.id); walkForbid(x.id); });
        };
        walkForbid(id);

        const opts = ['<option value="">(无，作为根分类)</option>'];
        const walk = (p) => {
            categories.filter(x => (x.parent_id || 0) === p).forEach(x => {
                if (x.direction === c.direction && !forbidden.has(x.id)) {
                    const indent = x.level > 1 ? '\u3000'.repeat(x.level - 1) + '└ ' : '';
                    const sel = c.parent_id === x.id ? 'selected' : '';
                    opts.push(`<option value="${x.id}" ${sel}>${indent}${x.name}</option>`);
                }
                walk(x.id);
            });
        };
        walk(0);
        document.getElementById('e-parent').innerHTML = opts.join('');
        dialog.showModal();
      };

      document.getElementById('edit-cancel').onclick = () => document.getElementById('edit-dialog').close();
      document.getElementById('edit-save').onclick = async () => {
        const id = Number(document.getElementById('e-id').value);
        const c = categories.find(x => x.id === id);
        const parentVal = document.getElementById('e-parent').value;
        const newParent = parentVal ? Number(parentVal) : null;
        const res = await fetch(`/api/categories/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: document.getElementById('e-name').value,
            regex: document.getElementById('e-regex').value,
            move: c.parent_id !== newParent,
            parent_id: newParent,
            sort_order: c.sort_order
          }),
        });
        if (res.ok) {
            document.getElementById('edit-dialog').close();
            loadCategories();
        }
      };

      window.deleteCategory = async (id) => {
        const c = categories.find(x => x.id === id);
        if (!confirm(`确定删除分类「${c.name}」吗？`)) return;
        const res = await fetch(`/api/categories/${id}`, { method: 'DELETE' });
        if (res.status === 409) alert('请先删除子分类');
        else loadCategories();
      };
    </script>
  </body>
</html>
