---
// Almanac Dashboard 2.0 - Visual Overhaul
import Sidebar from '../components/Sidebar.astro';
const title = '看板 · Almanac';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lucide-static@0.400.0/font/lucide.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <style>
      @font-face {
        font-family: 'Geist';
        src: url('https://cdn.jsdelivr.net/gh/vercel/geist-font@1.0.0/fonts/geist-sans/Geist-Regular.woff2') format('woff2');
      }
      body {
        font-family: 'Geist', system-ui, -apple-system, sans-serif;
      }
      [v-cloak] { display: none; }
      .glass {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }
      /* Custom Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen flex">
    <!-- Sidebar -->
    <Sidebar activePage="dashboard" />

    <!-- Main Content -->
    <main class="flex-1 ml-64 p-8 max-w-5xl">
      <!-- Header Area -->
      <header class="flex justify-between items-end mb-8">
        <div>
          <h1 class="text-3xl font-bold text-slate-800 tracking-tight">你好, <span id="greeting-name">...</span> 👋</h1>
          <p class="text-slate-500 mt-1">今天又是理财充满动力的一天。</p>
        </div>
        <div class="flex gap-3">
          <a id="admin-action" href="/admin/users" class="hidden bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2 rounded-xl font-medium transition-all flex items-center gap-2">
            <i class="lucide-users w-4 h-4"></i>
            <span>账户管理</span>
          </a>
          <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl font-medium shadow-sm shadow-blue-200 transition-all flex items-center gap-2">
            <i class="lucide-plus w-4 h-4"></i>
            <span>手动记账</span>
          </button>
        </div>
      </header>

      <!-- Grid Layout -->
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider">本月概览</h2>
        <input id="month-picker" type="month" class="text-sm bg-white border border-slate-200 rounded-lg px-3 py-1.5 text-slate-600 focus:outline-none focus:border-blue-300" />
      </div>
      <div class="grid grid-cols-3 gap-6 mb-8">
        <!-- Quick Stats -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-emerald-50 text-emerald-600 rounded-lg">
              <i class="lucide-trending-up w-5 h-5"></i>
            </div>
            <span class="text-sm font-medium text-slate-500">本月收入</span>
          </div>
          <div id="stat-income" class="text-2xl font-bold text-slate-800">¥ 0.00</div>
          <div id="stat-income-delta" class="text-xs text-emerald-500 mt-2 font-medium">相比上月 +0%</div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-rose-50 text-rose-600 rounded-lg">
              <i class="lucide-trending-down w-5 h-5"></i>
            </div>
            <span class="text-sm font-medium text-slate-500">本月支出</span>
          </div>
          <div id="stat-expense" class="text-2xl font-bold text-slate-800">¥ 0.00</div>
          <div id="stat-expense-delta" class="text-xs text-rose-400 mt-2 font-medium">相比上月 +0%</div>
        </div>

        <div class="bg-blue-600 p-6 rounded-2xl shadow-lg shadow-blue-100 text-white">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-blue-500 text-white rounded-lg">
              <i class="lucide-wallet w-5 h-5"></i>
            </div>
            <span class="text-sm font-medium opacity-80">当前结余</span>
          </div>
          <div id="stat-balance" class="text-2xl font-bold">¥ 0.00</div>
          <div class="text-xs opacity-70 mt-2">实时数据汇总</div>
        </div>
      </div>

      <!-- Unclassified alert -->
      <a id="unclassified-alert" href="#entries" class="hidden mb-8 items-center gap-3 bg-amber-50 border border-amber-200 text-amber-700 px-5 py-3 rounded-2xl hover:bg-amber-100 transition-all">
        <i class="lucide-alert-triangle w-5 h-5 shrink-0"></i>
        <span id="unclassified-text" class="text-sm font-medium"></span>
        <i class="lucide-chevron-right w-4 h-4 ml-auto"></i>
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main List -->
        <div class="lg:col-span-2 space-y-6">
          <section id="entries" class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
              <h3 class="font-bold text-slate-800 flex items-center gap-2">
                <i class="lucide-list text-blue-500 w-5 h-5"></i>
                账目明细
              </h3>
              <a href="/categories" class="text-xs text-blue-600 hover:underline">管理分类</a>
            </div>

            <div id="entries-loading" class="p-12 text-center text-slate-400">
              <div class="animate-pulse flex flex-col items-center">
                <div class="h-8 w-8 bg-slate-100 rounded-full mb-3"></div>
                <div class="h-2 w-24 bg-slate-100 rounded"></div>
              </div>
            </div>

            <div id="entries-list" class="divide-y divide-slate-50" hidden>
              <!-- Rows injected by JS -->
            </div>

            <div class="px-6 py-3 bg-slate-50 border-t border-slate-100">
                <p id="entries-total" class="text-xs text-slate-400 font-medium"></p>
            </div>
          </section>
        </div>

        <!-- Widgets Sidebar -->
        <div class="space-y-6">
          <!-- Expense breakdown chart -->
          <section class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
              <i class="lucide-pie-chart text-rose-500 w-5 h-5"></i>
              支出分布
            </h3>
            <div id="chart-empty" class="py-10 text-center text-sm text-slate-400" hidden>本月暂无支出数据</div>
            <div class="relative" style="height: 220px;">
              <canvas id="expense-chart"></canvas>
            </div>
          </section>

          <!-- Webhook Settings Widget -->
          <section class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
              <i class="lucide-zap text-amber-500 w-5 h-5"></i>
              自动化同步
            </h3>
            <div class="space-y-4">
              <div>
                <label class="text-[10px] uppercase tracking-wider font-bold text-slate-400 mb-1 block">接口地址</label>
                <div class="bg-slate-50 p-3 rounded-xl border border-slate-100 text-[11px] font-mono break-all text-slate-600" id="wh-url">
                  ...
                </div>
              </div>
              <button id="wh-copy" class="w-full py-2 bg-slate-800 hover:bg-slate-900 text-white text-sm font-medium rounded-xl transition-all">
                复制 Token
              </button>
              <p id="wh-msg" class="text-center text-[11px] min-h-[1em]"></p>
            </div>
          </section>

          <!-- Password Widget (Collapsible) -->
          <section class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm group">
            <div class="flex justify-between items-center cursor-pointer" onclick="document.getElementById('pw-form-container').classList.toggle('hidden')">
                <h3 class="font-bold text-slate-800 flex items-center gap-2">
                    <i class="lucide-key text-slate-400 w-5 h-5"></i>
                    安全设置
                </h3>
                <i class="lucide-chevron-down w-4 h-4 text-slate-300"></i>
            </div>
            <div id="pw-form-container" class="mt-4 space-y-3 hidden">
                <input id="old" type="password" placeholder="当前密码" class="w-full px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:outline-none focus:border-blue-300 transition-all" />
                <input id="new1" type="password" placeholder="新密码" class="w-full px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:outline-none focus:border-blue-300 transition-all" />
                <button id="pw-submit" class="w-full py-2 bg-blue-50 text-blue-600 text-sm font-bold rounded-xl hover:bg-blue-100 transition-all">确认更新</button>
                <p id="pw-msg" class="text-center text-[11px]"></p>
            </div>
          </section>
        </div>
      </div>
    </main>

    <script>
      // Shared logic (Copied & adapted from dashboard.astro)
      const greetingName = document.getElementById('greeting-name');
      const adminAction = document.getElementById('admin-action');

      fetch('/api/whoami')
        .then(r => {
          if (!r.ok) throw new Error();
          return r.json();
        })
        .then(d => {
          greetingName.textContent = d.username;
          if (d.is_admin) adminAction.classList.remove('hidden');
          loadWebhookToken();
          loadCategories().then(() => { loadEntries(); loadSummary(); loadChart(); });
        })
        .catch(() => window.location.href = '/login');

      // Webhook Logic
      const whUrl = document.getElementById('wh-url');
      const whMsg = document.getElementById('wh-msg');
      let currentToken = '';

      async function loadWebhookToken() {
        try {
          const res = await fetch('/api/webhook-token');
          const data = await res.json();
          currentToken = data.token;
          whUrl.textContent = data.token;
        } catch (e) {
          whMsg.textContent = '❌ 加载失败';
        }
      }

      document.getElementById('wh-copy').onclick = async () => {
        try {
          await navigator.clipboard.writeText(currentToken);
          whMsg.className = 'text-center text-[11px] text-emerald-500';
          whMsg.textContent = '✅ 已成功复制 Token';
          setTimeout(() => whMsg.textContent = '', 2000);
        } catch (e) {}
      };

      // Entry Logic
      let catsExpense = [];
      let catsIncome = [];

      async function loadCategories() {
        const res = await fetch('/api/categories');
        const data = await res.json();
        const cats = data.categories || [];
        const treeOrder = (list) => {
          const childrenOf = new Map();
          for (const c of list) {
            const key = c.parent_id == null ? 0 : c.parent_id;
            if (!childrenOf.has(key)) childrenOf.set(key, []);
            childrenOf.get(key).push(c);
          }
          const ordered = [];
          const walk = (p) => { (childrenOf.get(p) || []).forEach(c => { ordered.push(c); walk(c.id); }); };
          walk(0); return ordered;
        };
        // A single tree ordering across both directions: any category may now
        // be assigned to any entry (direction is derived from the category, not
        // the amount sign). Expense group first, then income, each tree-ordered.
        catsExpense = treeOrder(cats.filter(c => c.direction === -1));
        catsIncome = treeOrder(cats.filter(c => c.direction === 1));
      }

      // catOptions builds the reclassify dropdown listing ALL categories
      // (expense group then income group), grouped with <optgroup> so the user
      // can pick either direction. currentId marks the selected option.
      function catOptions(currentId) {
        let opts = `<option value="" ${!currentId ? 'selected' : ''}>未分类</option>`;
        const group = (label, list) => {
          if (!list.length) return '';
          let inner = '';
          list.forEach(c => {
            const sel = c.id === currentId ? 'selected' : '';
            const indent = c.level > 1 ? '\u3000'.repeat(c.level - 1) + '└ ' : '';
            inner += `<option value="${c.id}" ${sel}>${indent}${c.name}</option>`;
          });
          return `<optgroup label="${label}">${inner}</optgroup>`;
        };
        opts += group('支出', catsExpense);
        opts += group('收入', catsIncome);
        return opts;
      }

      async function loadEntries() {
        const list = document.getElementById('entries-list');
        const loading = document.getElementById('entries-loading');
        try {
          const res = await fetch('/api/entries?limit=20');
          const data = await res.json();
          loading.hidden = true;
          list.hidden = false;

          list.innerHTML = data.entries.map(e => {
            // Amounts are stored unsigned; direction comes from the assigned
            // category (1 income / -1 expense / 0 unclassified). An
            // unclassified entry has no direction -> neutral display.
            const dir = e.direction || 0;
            const isExpense = dir === -1;
            const isIncome = dir === 1;
            const yuan = (Math.abs(e.amount_cents) / 100).toFixed(2);
            const amtColor = isExpense ? 'text-rose-500' : (isIncome ? 'text-emerald-500' : 'text-slate-400');
            const sign = isExpense ? '-' : (isIncome ? '+' : '');
            const icon = isExpense ? 'arrow-up-right' : (isIncome ? 'arrow-down-left' : 'help-circle');
            const bgClass = !e.category_id ? 'bg-amber-50/30' : 'hover:bg-slate-50';
            
            return `
              <div class="px-6 py-4 flex items-center gap-4 transition-colors ${bgClass}">
                <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400">
                  <i class="lucide-${icon} w-5 h-5"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="font-bold text-slate-700 truncate">${e.raw_type}</span>
                    ${!e.category_id ? '<span class="px-1.5 py-0.5 bg-amber-100 text-amber-600 text-[10px] font-bold rounded">待分类</span>' : ''}
                  </div>
                  <div class="flex items-center gap-2 text-xs text-slate-400 mt-0.5">
                    <span>${e.record_time}</span>
                    ${e.category_path ? `<span class="opacity-50">/</span><span>${e.category_path}</span>` : ''}
                  </div>
                </div>
                <div class="text-right">
                  <div class="font-bold ${amtColor}">${sign}￥${yuan}</div>
                  <select class="entry-cat-select bg-transparent text-[11px] text-slate-400 outline-none mt-1 text-right" data-entry-id="${e.id}">
                    ${catOptions(e.category_id)}
                  </select>
                </div>
              </div>
            `;
          }).join('');

          document.getElementById('entries-total').textContent = `显示最近 ${data.entries.length} 条记录 (总计 ${data.total})`;
          bindCategorySelects();
        } catch (e) {
          loading.textContent = '❌ 加载失败';
        }
      }

      function bindCategorySelects() {
        document.querySelectorAll('.entry-cat-select').forEach(sel => {
          sel.onchange = async () => {
            sel.disabled = true;
            await fetch(`/api/entries/${sel.dataset.entryId}/category`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ category_id: sel.value ? Number(sel.value) : null }),
            });
            loadEntries();
            loadSummary();
            loadChart();
          };
        });
      }

      // ---- Summary cards + chart ----
      const fmtYuan = (cents) => '\u00a5 ' + (Math.abs(cents) / 100).toFixed(2);

      // Month picker: default to current month; changing it reloads everything.
      const monthPicker = document.getElementById('month-picker');
      function selectedMonth() {
        return monthPicker.value || new Date().toISOString().slice(0, 7);
      }
      monthPicker.value = new Date().toISOString().slice(0, 7);
      monthPicker.onchange = () => { loadSummary(); loadChart(); };

      // pctDelta renders the "vs last month" text; guards divide-by-zero.
      function pctDelta(cur, prev) {
        if (prev === 0) return cur === 0 ? '\u4e0e\u4e0a\u6708\u6301\u5e73' : '\u8f83\u4e0a\u6708 \u65b0\u589e';
        const p = Math.round(((cur - prev) / prev) * 100);
        return '\u76f8\u6bd4\u4e0a\u6708 ' + (p >= 0 ? '+' : '') + p + '%';
      }

      async function loadSummary() {
        try {
          const res = await fetch(`/api/summary?month=${selectedMonth()}`);
          const d = await res.json();
          document.getElementById('stat-income').textContent = fmtYuan(d.income_cents);
          document.getElementById('stat-expense').textContent = fmtYuan(d.expense_cents);
          document.getElementById('stat-balance').textContent = fmtYuan(d.balance_cents);
          document.getElementById('stat-income-delta').textContent = pctDelta(d.income_cents, d.prev_income_cents);
          document.getElementById('stat-expense-delta').textContent = pctDelta(d.expense_cents, d.prev_expense_cents);

          const alert = document.getElementById('unclassified-alert');
          if (d.unclassified_count > 0) {
            document.getElementById('unclassified-text').textContent =
              `\u6709 ${d.unclassified_count} \u7b14\u5f85\u5206\u7c7b\uff0c\u5171 ${fmtYuan(d.unclassified_cents)}\uff0c\u70b9\u51fb\u53bb\u5f52\u7c7b`;
            alert.classList.remove('hidden');
            alert.classList.add('flex');
          } else {
            alert.classList.add('hidden');
            alert.classList.remove('flex');
          }
        } catch (e) {}
      }

      const CHART_COLORS = ['#f43f5e', '#fb923c', '#facc15', '#4ade80', '#38bdf8', '#818cf8', '#c084fc', '#f472b6', '#94a3b8'];
      let expenseChart = null;

      async function loadChart() {
        const empty = document.getElementById('chart-empty');
        const canvas = document.getElementById('expense-chart');
        try {
          const res = await fetch(`/api/summary/by-category?month=${selectedMonth()}&direction=-1`);
          const d = await res.json();
          const slices = d.slices || [];
          if (expenseChart) { expenseChart.destroy(); expenseChart = null; }
          if (!slices.length) {
            empty.hidden = false;
            canvas.style.display = 'none';
            return;
          }
          empty.hidden = true;
          canvas.style.display = 'block';
          expenseChart = new Chart(canvas, {
            type: 'doughnut',
            data: {
              labels: slices.map(s => s.name),
              datasets: [{
                data: slices.map(s => s.total_cents / 100),
                backgroundColor: slices.map((_, i) => CHART_COLORS[i % CHART_COLORS.length]),
                borderWidth: 0,
              }],
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 12, padding: 12, font: { size: 11 } } },
                tooltip: {
                  callbacks: {
                    label: (ctx) => ` ${ctx.label}: \u00a5${ctx.parsed.toFixed(2)}`,
                  },
                },
              },
            },
          });
        } catch (e) {}
      }
    </script>
  </body>
</html>
