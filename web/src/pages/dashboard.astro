---
// Almanac Dashboard 2.0 - Visual Overhaul
import Sidebar from '../components/Sidebar.astro';
const title = '看板 · Almanac';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline src="https://cdn.jsdelivr.net/npm/lucide@0.400.0/dist/umd/lucide.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <style>
      @font-face {
        font-family: 'Geist';
        src: url('https://cdn.jsdelivr.net/gh/vercel/geist-font@1.0.0/fonts/geist-sans/Geist-Regular.woff2') format('woff2');
      }
      body {
        font-family: 'Geist', system-ui, -apple-system, sans-serif;
      }
      [v-cloak] { display: none; }
      .glass {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }
      /* Custom Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen flex">
    <!-- Sidebar -->
    <Sidebar activePage="dashboard" />

    <!-- Main Content -->
    <main class="flex-1 ml-64 p-8">
      <div class="mx-auto max-w-6xl">
      <!-- Header Area -->
      <header class="flex justify-between items-center mb-8">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center shrink-0">
            <i data-lucide="layout-dashboard" class="w-6 h-6"></i>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-slate-800 tracking-tight">你好，<span id="greeting-name">...</span></h1>
            <p class="text-slate-500 text-sm mt-0.5">今天又是理财充满动力的一天。</p>
          </div>
        </div>
        <div class="flex gap-3">
          <a id="admin-action" href="/admin/users" class="hidden bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2 rounded-xl font-medium transition-all flex items-center gap-2">
            <i data-lucide="users" class="w-4 h-4"></i>
            <span>账户管理</span>
          </a>
          <a href="/ledger" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl font-medium shadow-sm shadow-blue-200 transition-all flex items-center gap-2">
            <i data-lucide="plus" class="w-4 h-4"></i>
            <span>手动记账</span>
          </a>
        </div>
      </header>

      <!-- Grid Layout -->
      <div class="flex justify-between items-center mb-4">
        <h2 id="overview-title" class="text-sm font-bold text-slate-400 uppercase tracking-wider">本月概览</h2>
        <div class="flex items-center gap-2">
          <select id="period-type" class="text-sm bg-white border border-slate-200 rounded-lg px-3 py-1.5 text-slate-600 focus:outline-none focus:border-blue-300">
            <option value="month">月份</option>
            <option value="year">年份</option>
            <option value="all">全部</option>
          </select>
          <input id="month-picker" type="month" class="text-sm bg-white border border-slate-200 rounded-lg px-3 py-1.5 text-slate-600 focus:outline-none focus:border-blue-300" />
          <select id="year-picker" class="hidden text-sm bg-white border border-slate-200 rounded-lg px-3 py-1.5 text-slate-600 focus:outline-none focus:border-blue-300"></select>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-6 mb-8">
        <!-- Quick Stats -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-emerald-50 text-emerald-600 rounded-lg">
              <i data-lucide="trending-up" class="w-5 h-5"></i>
            </div>
            <span id="label-income" class="text-sm font-medium text-slate-500">本月收入</span>
          </div>
          <div id="stat-income" class="text-2xl font-bold text-slate-800">¥ 0.00</div>
          <div id="stat-income-delta" class="text-xs text-emerald-500 mt-2 font-medium">相比上月 +0%</div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-rose-50 text-rose-600 rounded-lg">
              <i data-lucide="trending-down" class="w-5 h-5"></i>
            </div>
            <span id="label-expense" class="text-sm font-medium text-slate-500">本月支出</span>
          </div>
          <div id="stat-expense" class="text-2xl font-bold text-slate-800">¥ 0.00</div>
          <div id="stat-expense-delta" class="text-xs text-rose-400 mt-2 font-medium">相比上月 +0%</div>
        </div>

        <div class="bg-blue-600 p-6 rounded-2xl shadow-lg shadow-blue-100 text-white">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-2 bg-blue-500 text-white rounded-lg">
              <i data-lucide="wallet" class="w-5 h-5"></i>
            </div>
            <span class="text-sm font-medium opacity-80">当前结余</span>
          </div>
          <div id="stat-balance" class="text-2xl font-bold">¥ 0.00</div>
          <div class="text-xs opacity-70 mt-2">实时数据汇总</div>
        </div>
      </div>

      <!-- Unclassified alert -->
      <a id="unclassified-alert" href="#entries" class="hidden mb-8 items-center gap-3 bg-amber-50 border border-amber-200 text-amber-700 px-5 py-3 rounded-2xl hover:bg-amber-100 transition-all">
        <i data-lucide="alert-triangle" class="w-5 h-5 shrink-0"></i>
        <span id="unclassified-text" class="text-sm font-medium"></span>
        <i data-lucide="chevron-right" class="w-4 h-4 ml-auto"></i>
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main List -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Breakdown charts: expense + income side by side -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <section class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
              <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
                <i data-lucide="pie-chart" class="text-rose-500 w-5 h-5"></i>
                支出分布
              </h3>
              <div id="expense-chart-empty" class="py-10 text-center text-sm text-slate-400" hidden>本月暂无支出数据</div>
              <div class="relative" style="height: 260px;">
                <canvas id="expense-chart"></canvas>
              </div>
            </section>
            <section class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
              <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
                <i data-lucide="pie-chart" class="text-emerald-500 w-5 h-5"></i>
                收入分布
              </h3>
              <div id="income-chart-empty" class="py-10 text-center text-sm text-slate-400" hidden>本月暂无收入数据</div>
              <div class="relative" style="height: 260px;">
                <canvas id="income-chart"></canvas>
              </div>
            </section>
          </div>

          <section id="entries" class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
              <h3 class="font-bold text-slate-800 flex items-center gap-2">
                <i data-lucide="list" class="text-blue-500 w-5 h-5"></i>
                账目明细
              </h3>
              <a href="/ledger" class="text-xs text-blue-600 hover:underline">查看全部</a>
            </div>

            <div id="entries-loading" class="p-12 text-center text-slate-400">
              <div class="animate-pulse flex flex-col items-center">
                <div class="h-8 w-8 bg-slate-100 rounded-full mb-3"></div>
                <div class="h-2 w-24 bg-slate-100 rounded"></div>
              </div>
            </div>

            <div id="entries-list" class="divide-y divide-slate-50" hidden>
              <!-- Rows injected by JS -->
            </div>

            <div class="px-6 py-3 bg-slate-50 border-t border-slate-100">
                <p id="entries-total" class="text-xs text-slate-400 font-medium"></p>
            </div>
          </section>
        </div>

        <!-- Widgets Sidebar -->
        <div class="space-y-6">
          <!-- Webhook Settings Widget (Collapsible) -->
          <section class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm group">
            <div class="flex justify-between items-center cursor-pointer" onclick="document.getElementById('wh-container').classList.toggle('hidden')">
              <h3 class="font-bold text-slate-800 flex items-center gap-2">
                <i data-lucide="zap" class="text-amber-500 w-5 h-5"></i>
                自动化同步
              </h3>
              <i data-lucide="chevron-down" class="w-4 h-4 text-slate-300"></i>
            </div>
            <div id="wh-container" class="mt-4 hidden">
            <p class="text-xs text-slate-500 leading-relaxed mb-4">让记账机器人或脚本把消费记录自动推送进来。向下面的接口发一条 <span class="font-semibold text-slate-700">POST</span> 请求即可,记得带上鉴权请求头。</p>
            <div class="space-y-4">
              <div>
                <label class="text-[10px] uppercase tracking-wider font-bold text-slate-400 mb-1 block">接口地址</label>
                <div class="flex items-stretch gap-2">
                  <div class="flex-1 bg-slate-50 p-3 rounded-xl border border-slate-100 text-[11px] font-mono break-all text-slate-600" id="wh-url">...</div>
                  <button id="wh-copy-url" title="复制接口地址" class="shrink-0 px-3 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-xl transition-all">
                    <i data-lucide="copy" class="w-4 h-4"></i>
                  </button>
                </div>
              </div>
              <div>
                <label class="text-[10px] uppercase tracking-wider font-bold text-slate-400 mb-1 block">鉴权请求头</label>
                <div class="flex items-stretch gap-2">
                  <div class="flex-1 bg-slate-50 p-3 rounded-xl border border-slate-100 text-[11px] font-mono break-all text-slate-600"><span class="text-slate-400">X-Webhook-Token:</span> <span id="wh-token">...</span></div>
                  <button id="wh-copy" title="复制 Token" class="shrink-0 px-3 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-xl transition-all">
                    <i data-lucide="copy" class="w-4 h-4"></i>
                  </button>
                </div>
              </div>
              <div>
                <div class="flex items-center justify-between mb-1">
                  <label class="text-[10px] uppercase tracking-wider font-bold text-slate-400 block">请求示例 (curl)</label>
                  <button id="wh-copy-curl" class="text-[10px] font-semibold text-blue-600 hover:text-blue-700 flex items-center gap-1">
                    <i data-lucide="copy" class="w-3 h-3"></i> 复制
                  </button>
                </div>
                <pre class="bg-slate-900 text-slate-100 p-3 rounded-xl text-[10px] font-mono leading-relaxed overflow-x-auto whitespace-pre" id="wh-curl">...</pre>
              </div>
              <div class="text-[11px] text-slate-500 leading-relaxed space-y-1">
                <p class="font-semibold text-slate-600">字段说明</p>
                <p><code class="text-slate-700">type</code> 描述/摘要 <span class="text-rose-500">(必填)</span>,如「午餐」「工资」</p>
                <p><code class="text-slate-700">amount</code> 金额 <span class="text-rose-500">(必填)</span>,正数(方向按分类判定)</p>
                <p><code class="text-slate-700">date</code> 时间 <span class="text-rose-500">(必填)</span>,ISO 8601 格式带时区,如 <code class="text-slate-700">2026-07-05T14:30:00+08:00</code></p>
              </div>
              <p id="wh-msg" class="text-center text-[11px] min-h-[1em]"></p>
            </div>
            </div>
          </section>

          <!-- Password Widget (Collapsible) -->
          <section class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm group">
            <div class="flex justify-between items-center cursor-pointer" onclick="document.getElementById('pw-form-container').classList.toggle('hidden')">
                <h3 class="font-bold text-slate-800 flex items-center gap-2">
                    <i data-lucide="key" class="text-slate-400 w-5 h-5"></i>
                    安全设置
                </h3>
                <i data-lucide="chevron-down" class="w-4 h-4 text-slate-300"></i>
            </div>
            <div id="pw-form-container" class="mt-4 space-y-3 hidden">
                <input id="old" type="password" placeholder="当前密码" class="w-full px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:outline-none focus:border-blue-300 transition-all" />
                <input id="new1" type="password" placeholder="新密码" class="w-full px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:outline-none focus:border-blue-300 transition-all" />
                <button id="pw-submit" class="w-full py-2 bg-blue-50 text-blue-600 text-sm font-bold rounded-xl hover:bg-blue-100 transition-all">确认更新</button>
                <p id="pw-msg" class="text-center text-[11px]"></p>
            </div>
          </section>
        </div>
      </div>
      </div>
    </main>

    <script>
      // Shared logic (Copied & adapted from dashboard.astro)
      const greetingName = document.getElementById('greeting-name');
      const adminAction = document.getElementById('admin-action');

      fetch('/api/whoami')
        .then(r => {
          if (!r.ok) throw new Error();
          return r.json();
        })
        .then(d => {
          greetingName.textContent = d.username;
          if (d.is_admin) adminAction.classList.remove('hidden');
          loadWebhookToken();
          loadCategories().then(() => { loadEntries(); loadSummary(); loadChart(); });
        })
        .catch(() => window.location.href = '/login?expired=1');

      // Webhook Logic
      const whUrl = document.getElementById('wh-url');
      const whToken = document.getElementById('wh-token');
      const whCurl = document.getElementById('wh-curl');
      const whMsg = document.getElementById('wh-msg');
      let currentToken = '';
      let currentUrl = '';
      let currentCurl = '';

      function flashMsg(text) {
        whMsg.className = 'text-center text-[11px] text-emerald-500';
        whMsg.textContent = text;
        setTimeout(() => whMsg.textContent = '', 2000);
      }

      async function loadWebhookToken() {
        try {
          const res = await fetch('/api/webhook-token');
          const data = await res.json();
          currentToken = data.token;
          currentUrl = window.location.origin + (data.path || '/api/webhook/entry');
          whUrl.textContent = currentUrl;
          whToken.textContent = currentToken;
          currentCurl = `curl -X POST ${currentUrl} \\
  -H "X-Webhook-Token: ${currentToken}" \\
  -H "Content-Type: application/json" \\
  -d '{"type":"午餐","amount":"25.5","date":"2026-07-05T14:30:00+08:00"}'`;
          whCurl.textContent = currentCurl;
        } catch (e) {
          whMsg.textContent = '❌ 加载失败';
        }
      }

      async function copyText(text, okMsg) {
        // navigator.clipboard 仅在安全上下文(HTTPS/localhost)可用；
        // 生产走明文 HTTP 时它是 undefined，需降级到 execCommand。
        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(text);
            flashMsg(okMsg);
            return;
          }
        } catch (e) { /* 落到下面的降级 */ }
        try {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.top = '-9999px';
          ta.setAttribute('readonly', '');
          document.body.appendChild(ta);
          ta.select();
          const ok = document.execCommand('copy');
          document.body.removeChild(ta);
          if (ok) flashMsg(okMsg);
          else { whMsg.className = 'text-center text-[11px] text-rose-500'; whMsg.textContent = '❌ 复制失败，请手动选择'; }
        } catch (e) {
          whMsg.className = 'text-center text-[11px] text-rose-500';
          whMsg.textContent = '❌ 复制失败，请手动选择';
        }
      }

      document.getElementById('wh-copy').onclick = () => copyText(currentToken, '✅ 已复制 Token');
      document.getElementById('wh-copy-url').onclick = () => copyText(currentUrl, '✅ 已复制接口地址');
      document.getElementById('wh-copy-curl').onclick = () => copyText(currentCurl, '✅ 已复制示例命令');

      // Entry Logic
      let catsExpense = [];
      let catsIncome = [];

      async function loadCategories() {
        const res = await fetch('/api/categories');
        const data = await res.json();
        const cats = data.categories || [];
        const treeOrder = (list) => {
          const childrenOf = new Map();
          for (const c of list) {
            const key = c.parent_id == null ? 0 : c.parent_id;
            if (!childrenOf.has(key)) childrenOf.set(key, []);
            childrenOf.get(key).push(c);
          }
          const ordered = [];
          const walk = (p) => { (childrenOf.get(p) || []).forEach(c => { ordered.push(c); walk(c.id); }); };
          walk(0); return ordered;
        };
        // A single tree ordering across both directions: any category may now
        // be assigned to any entry (direction is derived from the category, not
        // the amount sign). Expense group first, then income, each tree-ordered.
        catsExpense = treeOrder(cats.filter(c => c.direction === -1));
        catsIncome = treeOrder(cats.filter(c => c.direction === 1));
      }

      // catOptions builds the reclassify dropdown listing ALL categories
      // (expense group then income group), grouped with <optgroup> so the user
      // can pick either direction. currentId marks the selected option.
      function catOptions(currentId) {
        let opts = `<option value="" ${!currentId ? 'selected' : ''}>未分类</option>`;
        const group = (label, list) => {
          if (!list.length) return '';
          let inner = '';
          list.forEach(c => {
            const sel = c.id === currentId ? 'selected' : '';
            const indent = c.level > 1 ? '\u3000'.repeat(c.level - 1) + '└ ' : '';
            inner += `<option value="${c.id}" ${sel}>${indent}${c.name}</option>`;
          });
          return `<optgroup label="${label}">${inner}</optgroup>`;
        };
        opts += group('支出', catsExpense);
        opts += group('收入', catsIncome);
        return opts;
      }

      // ---- Icon mapping (Lucide) ---- kept in sync with ledger.astro so the
      // dashboard recent list and the full ledger render icons identically.
      const ICON_RULES = [
        { icon: 'utensils',       kw: ['餐饮', '吃', '饭', '午餐', '晚餐', '早餐', '外卖', '美食', 'food', 'meal'] },
        { icon: 'coffee',         kw: ['咖啡', '奶茶', '饮料', '星巴克', 'coffee', 'tea'] },
        { icon: 'shopping-cart',  kw: ['购物', '超市', '采购', '淘宝', '京东', 'shopping'] },
        { icon: 'shopping-bag',   kw: ['服装', '衣服', '鞋', '包', '美妆', '化妆品'] },
        { icon: 'car',            kw: ['交通', '打车', '打的', '出行', '汽车', '加油', '油费', 'taxi', 'uber'] },
        { icon: 'bus',            kw: ['公交', '地铁', '高铁', '火车', '火车票', '地铁票'] },
        { icon: 'plane',          kw: ['机票', '飞机', '航班', 'flight'] },
        { icon: 'home',           kw: ['房租', '房贷', '物业', '房子', '租金'] },
        { icon: 'zap',            kw: ['水电', '电费', '水费', '燃气', '水电煤'] },
        { icon: 'wifi',           kw: ['话费', '网费', '宽带', '流量', '通信'] },
        { icon: 'smartphone',     kw: ['手机', '数码', '电子产品'] },
        { icon: 'gamepad-2',      kw: ['游戏', '娱乐', '充值'] },
        { icon: 'clapperboard',   kw: ['电影', '看电影', 'ktv'] },
        { icon: 'heart-pulse',    kw: ['医疗', '看病', '医院', '药', '体检', '健康'] },
        { icon: 'graduation-cap', kw: ['教育', '学习', '培训', '学费', '书', '图书'] },
        { icon: 'baby',           kw: ['孩子', '婴儿', '小孩', '母婴'] },
        { icon: 'gift',           kw: ['礼物', '礼金', '人情', '红包'] },
        { icon: 'paw-print',      kw: ['宠物', '猫', '狗'] },
        { icon: 'dumbbell',       kw: ['健身', '运动', '体育'] },
        { icon: 'briefcase',      kw: ['工资', '薪资', '工作', 'salary'] },
        { icon: 'trending-up',    kw: ['理财', '投资', '股票', '基金', '收益', '利息'] },
        { icon: 'award',          kw: ['奖金', '红利', '奖励', '提成'] },
        { icon: 'landmark',       kw: ['银行', '转账', '储蓄'] },
        { icon: 'receipt',        kw: ['报销', '发票', '税'] },
      ];
      function iconFor(e) {
        const hay = ((e.category_name || '') + ' ' + (e.category_path || '') + ' ' + (e.raw_type || '')).toLowerCase();
        for (const r of ICON_RULES) {
          if (r.kw.some(k => hay.includes(k.toLowerCase()))) return r.icon;
        }
        const dir = e.direction || 0;
        return dir === -1 ? 'arrow-up-right' : (dir === 1 ? 'arrow-down-left' : 'help-circle');
      }

      async function loadEntries() {
        const list = document.getElementById('entries-list');
        const loading = document.getElementById('entries-loading');
        try {
          const res = await fetch(`/api/entries?limit=8&${periodQuery()}`);
          const data = await res.json();
          loading.hidden = true;
          list.hidden = false;

          list.innerHTML = data.entries.map(e => {
            // Amounts are stored unsigned; direction comes from the assigned
            // category (1 income / -1 expense / 0 unclassified). An
            // unclassified entry has no direction -> neutral display.
            const dir = e.direction || 0;
            const isExpense = dir === -1;
            const isIncome = dir === 1;
            const yuan = (Math.abs(e.amount_cents) / 100).toFixed(2);
            const amtColor = isExpense ? 'text-rose-500' : (isIncome ? 'text-emerald-500' : 'text-slate-400');
            const sign = isExpense ? '-' : (isIncome ? '+' : '');
            const icon = iconFor(e);
            const iconTint = isExpense ? 'bg-rose-50 text-rose-500' : (isIncome ? 'bg-emerald-50 text-emerald-500' : 'bg-slate-100 text-slate-400');
            const bgClass = !e.category_id ? 'bg-amber-50/30' : 'hover:bg-slate-50';
            
            return `
              <div class="px-6 py-4 flex items-center gap-4 transition-colors ${bgClass}">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 ${iconTint}">
                  <i data-lucide="${icon}" class="w-5 h-5"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="font-bold text-slate-700 truncate">${e.raw_type || e.category_name || '未分类'}</span>
                    ${!e.category_id ? '<span class="px-1.5 py-0.5 bg-amber-100 text-amber-600 text-[10px] font-bold rounded">待分类</span>' : ''}
                  </div>
                  <div class="flex items-center gap-2 text-xs text-slate-400 mt-0.5">
                    <span>${e.record_time}</span>
                    ${e.category_path ? `<span class="opacity-50">/</span><span>${e.category_path}</span>` : ''}
                  </div>
                </div>
                <div class="text-right">
                  <div class="font-bold ${amtColor}">${sign}￥${yuan}</div>
                  <select class="entry-cat-select bg-transparent text-[11px] text-slate-400 outline-none mt-1 text-right" data-entry-id="${e.id}">
                    ${catOptions(e.category_id)}
                  </select>
                </div>
              </div>
            `;
          }).join('');
          window.lucide?.createIcons();

          document.getElementById('entries-total').textContent = `${periodNoun()}共 ${data.total} 条，显示最近 ${data.entries.length} 条，完整明细见「账本」`;
          bindCategorySelects();
        } catch (e) {
          loading.textContent = '❌ 加载失败';
        }
      }

      function bindCategorySelects() {
        document.querySelectorAll('.entry-cat-select').forEach(sel => {
          sel.onchange = async () => {
            sel.disabled = true;
            await fetch(`/api/entries/${sel.dataset.entryId}/category`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ category_id: sel.value ? Number(sel.value) : null }),
            });
            loadEntries();
            loadSummary();
            loadChart();
          };
        });
      }

      // ---- Summary cards + chart ----
      const fmtYuan = (cents) => (cents < 0 ? '-\u00a5 ' : '\u00a5 ') + (Math.abs(cents) / 100).toFixed(2);

      // ---- Period selector: month / year / all ----
      const periodType = document.getElementById('period-type');
      const monthPicker = document.getElementById('month-picker');
      const yearPicker = document.getElementById('year-picker');
      const overviewTitle = document.getElementById('overview-title');
      const labelIncome = document.getElementById('label-income');
      const labelExpense = document.getElementById('label-expense');
      const incomeDelta = document.getElementById('stat-income-delta');
      const expenseDelta = document.getElementById('stat-expense-delta');

      const now = new Date();
      monthPicker.value = now.toISOString().slice(0, 7);
      // Populate the year dropdown: current year back through 6 prior years.
      const curYear = now.getFullYear();
      for (let y = curYear; y >= curYear - 6; y--) {
        const opt = document.createElement('option');
        opt.value = String(y);
        opt.textContent = y + '\u5e74';
        yearPicker.appendChild(opt);
      }
      yearPicker.value = String(curYear);

      // currentPeriod returns the {period, value} pair for the active selection.
      function currentPeriod() {
        const p = periodType.value;
        if (p === 'year') return { period: 'year', value: yearPicker.value };
        if (p === 'all') return { period: 'all', value: '' };
        return { period: 'month', value: monthPicker.value || now.toISOString().slice(0, 7) };
      }

      // periodQuery builds the shared `?period=&value=` query string.
      function periodQuery() {
        const { period, value } = currentPeriod();
        return value ? `period=${period}&value=${value}` : `period=${period}`;
      }

      // periodNoun returns the active period label (本月/本年/累计) for reuse in
      // card labels and list captions.
      function periodNoun() {
        const p = periodType.value;
        return p === 'year' ? '\u672c\u5e74' : (p === 'all' ? '\u7d2f\u8ba1' : '\u672c\u6708');
      }

      // syncPeriodUI toggles the value selector visibility and relabels cards.
      function syncPeriodUI() {
        const p = periodType.value;
        monthPicker.classList.toggle('hidden', p !== 'month');
        yearPicker.classList.toggle('hidden', p !== 'year');
        const noun = periodNoun();
        overviewTitle.textContent = noun + '\u6982\u89c8';
        labelIncome.textContent = noun + '\u6536\u5165';
        labelExpense.textContent = noun + '\u652f\u51fa';
        // All-time has no comparison period: hide deltas entirely.
        const hideDelta = (p === 'all');
        incomeDelta.classList.toggle('hidden', hideDelta);
        expenseDelta.classList.toggle('hidden', hideDelta);
      }

      // deltaWord is the "vs prior period" prefix, tracking the period type.
      function deltaWord() {
        return periodType.value === 'year' ? '\u8f83\u4e0a\u5e74 ' : '\u8f83\u4e0a\u6708 ';
      }

      function reloadAll() { syncPeriodUI(); loadEntries(); loadSummary(); loadChart(); }
      periodType.onchange = reloadAll;
      monthPicker.onchange = () => { loadEntries(); loadSummary(); loadChart(); };
      yearPicker.onchange = () => { loadEntries(); loadSummary(); loadChart(); };
      syncPeriodUI();

      // pctDelta renders the "vs prior period" text; guards divide-by-zero.
      function pctDelta(cur, prev) {
        // 上期为 0 时百分比无意义，改为直接展示本期新增的实际金额。
        if (prev === 0) return cur === 0 ? '\u4e0e\u4e0a\u671f\u6301\u5e73' : deltaWord() + fmtYuan(cur);
        const p = Math.round(((cur - prev) / prev) * 100);
        return deltaWord() + (p >= 0 ? '+' : '') + p + '%';
      }

      async function loadSummary() {
        try {
          const res = await fetch(`/api/summary?${periodQuery()}`);
          const d = await res.json();
          document.getElementById('stat-income').textContent = fmtYuan(d.income_cents);
          document.getElementById('stat-expense').textContent = fmtYuan(d.expense_cents);
          document.getElementById('stat-balance').textContent = fmtYuan(d.balance_cents);
          document.getElementById('stat-income-delta').textContent = pctDelta(d.income_cents, d.prev_income_cents);
          document.getElementById('stat-expense-delta').textContent = pctDelta(d.expense_cents, d.prev_expense_cents);

          const alert = document.getElementById('unclassified-alert');
          if (d.unclassified_count > 0) {
            document.getElementById('unclassified-text').textContent =
              `\u6709 ${d.unclassified_count} \u7b14\u5f85\u5206\u7c7b\uff0c\u5171 ${fmtYuan(d.unclassified_cents)}\uff0c\u70b9\u51fb\u53bb\u5f52\u7c7b`;
            alert.classList.remove('hidden');
            alert.classList.add('flex');
          } else {
            alert.classList.add('hidden');
            alert.classList.remove('flex');
          }
        } catch (e) {}
      }

      // 支出：暖色系（红/橙/黄），深浅+色相交错排，相邻扇区对比明显
      const EXPENSE_COLORS = ['#e11d48', '#fdba74', '#b91c1c', '#facc15', '#ea580c', '#fca5a5', '#f59e0b', '#fde047', '#f43f5e', '#dc2626', '#fb923c', '#eab308', '#ef4444', '#fda4af', '#f97316', '#fbbf24'];
      // 收入：绿色系（green/emerald 为主，末尾补少量 lime/teal 黄绿·蓝绿凑满 16），交错排
      const INCOME_COLORS  = ['#16a34a', '#6ee7b7', '#047857', '#4ade80', '#065f46', '#86efac', '#10b981', '#166534', '#34d399', '#15803d', '#a3e635', '#14b8a6', '#22c55e', '#2dd4bf', '#059669', '#84cc16'];
      let expenseChart = null;
      let incomeChart = null;

      function loadChart() {
        renderChart({ direction: -1, canvasId: 'expense-chart', emptyId: 'expense-chart-empty', colors: EXPENSE_COLORS, get: () => expenseChart, set: (c) => { expenseChart = c; } });
        renderChart({ direction: 1, canvasId: 'income-chart', emptyId: 'income-chart-empty', colors: INCOME_COLORS, get: () => incomeChart, set: (c) => { incomeChart = c; } });
      }

      async function renderChart({ direction, canvasId, emptyId, colors, get, set }) {
        const empty = document.getElementById(emptyId);
        const canvas = document.getElementById(canvasId);
        try {
          const res = await fetch(`/api/summary/by-category?${periodQuery()}&direction=${direction}`);
          const d = await res.json();
          const slices = d.slices || [];
          const existing = get();
          if (existing) { existing.destroy(); set(null); }
          if (!slices.length) {
            empty.hidden = false;
            canvas.style.display = 'none';
            return;
          }
          empty.hidden = true;
          canvas.style.display = 'block';
          set(new Chart(canvas, {
            type: 'doughnut',
            data: {
              labels: slices.map(s => s.name),
              datasets: [{
                data: slices.map(s => s.total_cents / 100),
                backgroundColor: slices.map((_, i) => colors[i % colors.length]),
                borderWidth: 0,
              }],
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 12, padding: 12, font: { size: 11 } } },
                tooltip: {
                  callbacks: {
                    label: (ctx) => ` ${ctx.label}: \u00a5${ctx.parsed.toFixed(2)}`,
                  },
                },
              },
            },
          }));
        } catch (e) {}
      }
    </script>
  </body>
</html>
