---
// Almanac dashboard (placeholder).
// Client-side guard: calls /api/whoami; if unauthorized, redirect to /login.
// Ledger features will be filled in later iterations.
const title = '看板 · Almanac';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root { color-scheme: light dark; }
      body {
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        max-width: 48rem;
        margin: 3rem auto;
        padding: 0 1.5rem;
        line-height: 1.6;
      }
      header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        border-bottom: 1px solid #8883;
        padding-bottom: 1rem;
      }
      h1 { font-size: 1.6rem; margin: 0; }
      .user { color: #888; font-size: 0.9rem; }
      .admin-link {
        color: #2563eb;
        text-decoration: none;
        font-size: 0.85rem;
        margin-right: 0.6rem;
      }
      .logout {
        border: 1px solid #8884;
        background: transparent;
        border-radius: 8px;
        padding: 0.35rem 0.8rem;
        cursor: pointer;
        color: inherit;
        font-size: 0.85rem;
      }
      .card {
        border: 1px solid #8883;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-top: 2rem;
      }
      .muted { color: #888; }
      #gate { color: #888; }
      .pw-form { margin-top: 1rem; max-width: 20rem; }
      .pw-form label { display: block; font-size: 0.85rem; margin: 0.6rem 0 0.3rem; }
      .pw-form input {
        width: 100%;
        box-sizing: border-box;
        padding: 0.55rem 0.7rem;
        border: 1px solid #8884;
        border-radius: 8px;
        font-size: 0.95rem;
        background: Field;
        color: FieldText;
      }
      .pw-form button {
        margin-top: 0.9rem;
        padding: 0.55rem 1rem;
        border: none;
        border-radius: 8px;
        background: #2563eb;
        color: #fff;
        cursor: pointer;
      }
      .pw-form button:disabled { opacity: 0.6; cursor: default; }
      .pw-msg { font-size: 0.85rem; min-height: 1.2em; margin-top: 0.5rem; }
      .pw-msg.ok { color: #16a34a; }
      .pw-msg.err { color: #dc2626; }
      .wh-row { margin-top: 0.9rem; }
      .wh-label { font-size: 0.8rem; color: #888; margin-bottom: 0.25rem; }
      .wh-code {
        font-family: ui-monospace, "Cascadia Code", monospace;
        font-size: 0.85rem;
        background: #8881;
        border: 1px solid #8883;
        border-radius: 8px;
        padding: 0.5rem 0.7rem;
        word-break: break-all;
        user-select: all;
      }
      .wh-actions { margin-top: 0.9rem; display: flex; gap: 0.6rem; flex-wrap: wrap; }
      .wh-actions button {
        padding: 0.45rem 0.9rem;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.85rem;
        border: 1px solid #8884;
        background: transparent;
        color: inherit;
      }
      .wh-actions .primary { border: none; background: #2563eb; color: #fff; }
      .wh-msg { font-size: 0.8rem; min-height: 1.1em; margin-top: 0.5rem; color: #16a34a; }
      .wh-msg.err { color: #dc2626; }
      .entry-row {
        border-top: 1px solid #8882;
        padding: 0.8rem 0;
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 0.8rem;
        align-items: baseline;
      }
      .entry-row:first-child { border-top: none; padding-top: 0; }
      .entry-time { font-size: 0.85rem; color: #888; white-space: nowrap; }
      .entry-desc { font-size: 0.95rem; }
      .entry-cat { font-size: 0.75rem; color: #888; margin-top: 0.15rem; }
      .entry-path { font-size: 0.72rem; color: #6b7280; margin-top: 0.15rem; }
      .entry-cat-select {
        font-size: 0.75rem;
        color: #555;
        margin-top: 0.2rem;
        padding: 0.1rem 0.3rem;
        border: 1px solid #ddd;
        border-radius: 4px;
        background: #fff;
        max-width: 12rem;
      }
      .entry-cat-select.unclassified {
        color: #b45309;
        border-color: #f59e0b;
        background: #fffbeb;
      }
      .entry-cat-select:disabled { opacity: 0.5; }
      .entry-amount { font-size: 0.95rem; font-weight: 600; white-space: nowrap; }
      .entry-amount.expense { color: #dc2626; }
      .entry-amount.income { color: #16a34a; }
      #entries-list { margin-top: 1rem; }
      .entries-total { font-size: 0.8rem; color: #888; margin-top: 0.8rem; }
      .entries-empty { color: #888; margin-top: 1rem; }
    </style>
  </head>
  <body>
    <div id="gate">加载中…</div>
    <div id="app" hidden>
      <header>
        <h1>📖 记账本</h1>
        <div>
          <span class="user" id="user"></span>
          <a class="admin-link" id="admin-link" href="/admin/users" hidden>账户管理</a>
          <button class="logout" id="logout">退出</button>
        </div>
      </header>

      <div class="card">
        <strong>✅ 你已登录</strong>
        <p class="muted">
          这是看板占位页。接下来的迭代会在这里填入账目明细、分类树管理、
          CSV 导入和汇总统计。
        </p>
      </div>

      <div class="card">
        <strong>🔌 Webhook 接入</strong>
        <p class="muted">iOS 快捷指令把账单 POST 到下方接口，请求头带上 token。Body 三要素：<code>date</code>（带时区 ISO 8601）、<code>type</code>（描述）、<code>amount</code>（支出为负、收入为正）。</p>
        <div class="wh-row">
          <div class="wh-label">接口地址（POST）</div>
          <div class="wh-code" id="wh-url">…</div>
        </div>
        <div class="wh-row">
          <div class="wh-label">请求头</div>
          <div class="wh-code" id="wh-header">…</div>
        </div>
        <div class="wh-actions">
          <button class="primary" id="wh-copy">复制 token</button>
          <button id="wh-reset">重置 token</button>
        </div>
        <p class="wh-msg" id="wh-msg"></p>
      </div>

      <div class="card">
        <strong>🔑 修改密码</strong>
        <form class="pw-form" id="pw-form">
          <label for="old">当前密码</label>
          <input id="old" type="password" autocomplete="current-password" required />
          <label for="new1">新密码（至少 6 位）</label>
          <input id="new1" type="password" autocomplete="new-password" required />
          <label for="new2">确认新密码</label>
          <input id="new2" type="password" autocomplete="new-password" required />
          <button type="submit" id="pw-submit">修改密码</button>
          <p class="pw-msg" id="pw-msg"></p>
        </form>
      </div>

      <div class="card">
        <strong>📊 账目明细</strong>
        <p class="muted">最近的账目记录（倒序，待分类的显示为“未分类”）。<a href="/categories" style="color:#2563eb;text-decoration:none;">管理分类 →</a></p>
        <div id="entries-loading" class="muted" style="margin-top:1rem;">加载中…</div>
        <div id="entries-list" hidden></div>
        <div id="entries-error" class="pw-msg err" hidden></div>
      </div>
    </div>

    <script>
      const gate = document.getElementById('gate');
      const app = document.getElementById('app');

      fetch('/api/whoami')
        .then((r) => {
          if (!r.ok) throw new Error('unauthorized');
          return r.json();
        })
        .then((d) => {
          document.getElementById('user').textContent = `${d.username} ·`;
          if (d.is_admin) document.getElementById('admin-link').hidden = false;
          gate.hidden = true;
          app.hidden = false;
          loadWebhookToken();
          loadCategories().then(loadEntries);
        })
        .catch(() => {
          window.location.href = '/login';
        });

      document.getElementById('logout').addEventListener('click', async () => {
        await fetch('/api/logout', { method: 'POST' }).catch(() => {});
        window.location.href = '/login';
      });

      const whUrl = document.getElementById('wh-url');
      const whHeader = document.getElementById('wh-header');
      const whMsg = document.getElementById('wh-msg');
      let currentToken = '';

      function renderToken(data) {
        currentToken = data.token;
        whUrl.textContent = `${window.location.origin}${data.path}`;
        whHeader.textContent = `X-Webhook-Token: ${data.token}`;
      }

      async function loadWebhookToken() {
        try {
          const res = await fetch('/api/webhook-token');
          if (!res.ok) throw new Error('failed');
          renderToken(await res.json());
        } catch (e) {
          whMsg.className = 'wh-msg err';
          whMsg.textContent = '无法获取 token';
        }
      }

      document.getElementById('wh-copy').addEventListener('click', async () => {
        whMsg.className = 'wh-msg';
        try {
          await navigator.clipboard.writeText(currentToken);
          whMsg.textContent = '✅ token 已复制到剪贴板';
        } catch (e) {
          whMsg.className = 'wh-msg err';
          whMsg.textContent = '复制失败，请长按上方 token 手动复制';
        }
      });

      document.getElementById('wh-reset').addEventListener('click', async () => {
        if (!confirm('重置后旧 token 立即失效，iOS 快捷指令需同步更新。确定？')) return;
        whMsg.className = 'wh-msg';
        whMsg.textContent = '重置中…';
        try {
          const res = await fetch('/api/webhook-token/reset', { method: 'POST' });
          if (!res.ok) throw new Error('failed');
          renderToken(await res.json());
          whMsg.textContent = '✅ token 已重置，请更新快捷指令';
        } catch (e) {
          whMsg.className = 'wh-msg err';
          whMsg.textContent = '重置失败，请重试';
        }
      });

      const pwForm = document.getElementById('pw-form');
      const pwBtn = document.getElementById('pw-submit');
      const pwMsg = document.getElementById('pw-msg');
      pwForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        pwMsg.className = 'pw-msg';
        pwMsg.textContent = '';
        const old = document.getElementById('old').value;
        const n1 = document.getElementById('new1').value;
        const n2 = document.getElementById('new2').value;
        if (n1 !== n2) {
          pwMsg.className = 'pw-msg err';
          pwMsg.textContent = '两次输入的新密码不一致';
          return;
        }
        if (n1.length < 6) {
          pwMsg.className = 'pw-msg err';
          pwMsg.textContent = '新密码至少 6 位';
          return;
        }
        pwBtn.disabled = true;
        pwBtn.textContent = '提交中…';
        try {
          const res = await fetch('/api/change-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ old_password: old, new_password: n1 }),
          });
          if (res.ok) {
            pwMsg.className = 'pw-msg ok';
            pwMsg.textContent = '修改成功，即将跳转登录页…';
            setTimeout(() => { window.location.href = '/login'; }, 1500);
            return;
          }
          const data = await res.json().catch(() => ({}));
          pwMsg.className = 'pw-msg err';
          pwMsg.textContent =
            data.error === 'wrong old password' ? '当前密码错误'
            : data.error === 'password too short' ? '新密码至少 6 位'
            : '修改失败，请重试';
        } catch (e) {
          pwMsg.className = 'pw-msg err';
          pwMsg.textContent = '无法连接服务器';
        } finally {
          pwBtn.disabled = false;
          pwBtn.textContent = '修改密码';
        }
      });

      // Load entries list
      const entriesLoading = document.getElementById('entries-loading');
      const entriesList = document.getElementById('entries-list');
      const entriesError = document.getElementById('entries-error');

      // Categories cached for the reclassify dropdowns, split by direction.
      let catsExpense = [];
      let catsIncome = [];

      async function loadCategories() {
        try {
          const res = await fetch('/api/categories');
          if (!res.ok) return;
          const data = await res.json();
          const cats = data.categories || [];
          catsExpense = treeOrder(cats.filter(c => c.direction === -1));
          catsIncome = treeOrder(cats.filter(c => c.direction === 1));
        } catch (e) { /* dropdowns just stay empty on failure */ }
      }

      // Reorder a flat category list into depth-first order so children sit
      // directly under their parent. Input is already sorted by level, then
      // sort_order, then id, so per-parent child order is preserved.
      function treeOrder(list) {
        const childrenOf = new Map();
        for (const c of list) {
          const key = c.parent_id == null ? 0 : c.parent_id;
          if (!childrenOf.has(key)) childrenOf.set(key, []);
          childrenOf.get(key).push(c);
        }
        const ordered = [];
        const walk = (parentKey) => {
          for (const c of childrenOf.get(parentKey) || []) {
            ordered.push(c);
            walk(c.id);
          }
        };
        walk(0);
        return ordered;
      }

      // Build the <option> list for an entry given its direction and current id.
      // Non-root categories are indented by level to show the hierarchy.
      function catOptions(isExpense, currentId) {
        const list = isExpense ? catsExpense : catsIncome;
        let opts = `<option value=""${!currentId ? ' selected' : ''}>未分类</option>`;
        for (const c of list) {
          const sel = c.id === currentId ? ' selected' : '';
          const indent = c.level > 1 ? '\u3000'.repeat(c.level - 1) + '└ ' : '';
          opts += `<option value="${c.id}"${sel}>${indent}${escapeHTML(c.name)}</option>`;
        }
        return opts;
      }

      async function loadEntries() {
        try {
          const res = await fetch('/api/entries?limit=20');
          if (!res.ok) throw new Error('failed');
          const data = await res.json();
          entriesLoading.hidden = true;
          if (data.entries.length === 0) {
            entriesList.innerHTML = '<div class="entries-empty">还没有账目记录</div>';
            entriesList.hidden = false;
            return;
          }
          entriesList.innerHTML = data.entries.map(e => {
            const cents = e.amount_cents;
            const isExpense = cents < 0;
            const yuan = (Math.abs(cents) / 100).toFixed(2);
            const amtClass = isExpense ? 'expense' : 'income';
            const amtText = isExpense ? `-¥${yuan}` : `+¥${yuan}`;
            const curId = e.category_id || 0;
            const unclassified = curId ? '' : ' unclassified';
            const pathLine = e.category_path
              ? `<div class="entry-path">${escapeHTML(e.category_path)}</div>`
              : '';
            return `<div class="entry-row">
              <div class="entry-time">${e.record_time}</div>
              <div>
                <div class="entry-desc">${escapeHTML(e.raw_type)}</div>
                ${pathLine}
                <select class="entry-cat-select${unclassified}" data-entry-id="${e.id}">${catOptions(isExpense, curId)}</select>
              </div>
              <div class="entry-amount ${amtClass}">${amtText}</div>
            </div>`;
          }).join('');
          entriesList.innerHTML += `<div class="entries-total">共 ${data.total} 条记录</div>`;
          entriesList.hidden = false;
          bindCategorySelects();
        } catch (e) {
          entriesLoading.hidden = true;
          entriesError.textContent = '加载失败，请刷新重试';
          entriesError.hidden = false;
        }
      }

      // Wire each dropdown to PATCH the entry's category on change.
      function bindCategorySelects() {
        for (const sel of entriesList.querySelectorAll('.entry-cat-select')) {
          sel.addEventListener('change', async () => {
            const id = sel.dataset.entryId;
            const val = sel.value;
            const body = { category_id: val ? Number(val) : null };
            const prev = sel.dataset.prev || '';
            sel.disabled = true;
            try {
              const res = await fetch(`/api/entries/${id}/category`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body),
              });
              if (!res.ok) throw new Error('failed');
              // Reload so the path line and styling reflect the new category.
              loadEntries();
            } catch (e) {
              sel.value = prev; // revert on failure
              entriesError.textContent = '修改分类失败，请重试';
              entriesError.hidden = false;
            } finally {
              sel.disabled = false;
            }
          });
          sel.dataset.prev = sel.value;
        }
      }

      function escapeHTML(s) {
        const div = document.createElement('div');
        div.textContent = s;
        return div.innerHTML;
      }
    </script>
  </body>
</html>
