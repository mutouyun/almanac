---
// Almanac dashboard (placeholder).
// Client-side guard: calls /api/whoami; if unauthorized, redirect to /login.
// Ledger features will be filled in later iterations.
const title = '看板 · Almanac';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root { color-scheme: light dark; }
      body {
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        max-width: 48rem;
        margin: 3rem auto;
        padding: 0 1.5rem;
        line-height: 1.6;
      }
      header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        border-bottom: 1px solid #8883;
        padding-bottom: 1rem;
      }
      h1 { font-size: 1.6rem; margin: 0; }
      .user { color: #888; font-size: 0.9rem; }
      .logout {
        border: 1px solid #8884;
        background: transparent;
        border-radius: 8px;
        padding: 0.35rem 0.8rem;
        cursor: pointer;
        color: inherit;
        font-size: 0.85rem;
      }
      .card {
        border: 1px solid #8883;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-top: 2rem;
      }
      .muted { color: #888; }
      #gate { color: #888; }
    </style>
  </head>
  <body>
    <div id="gate">加载中…</div>
    <div id="app" hidden>
      <header>
        <h1>📖 记账本</h1>
        <div>
          <span class="user" id="user"></span>
          <button class="logout" id="logout">退出</button>
        </div>
      </header>

      <div class="card">
        <strong>✅ 你已登录</strong>
        <p class="muted">
          这是看板占位页。接下来的迭代会在这里填入账目明细、分类树管理、
          CSV 导入和汇总统计。
        </p>
      </div>
    </div>

    <script>
      const gate = document.getElementById('gate');
      const app = document.getElementById('app');

      fetch('/api/whoami')
        .then((r) => {
          if (!r.ok) throw new Error('unauthorized');
          return r.json();
        })
        .then((d) => {
          document.getElementById('user').textContent = `${d.username} ·`;
          gate.hidden = true;
          app.hidden = false;
        })
        .catch(() => {
          window.location.href = '/login';
        });

      document.getElementById('logout').addEventListener('click', async () => {
        await fetch('/api/logout', { method: 'POST' }).catch(() => {});
        window.location.href = '/login';
      });
    </script>
  </body>
</html>
