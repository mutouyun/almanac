---
// Almanac MVP landing page.
// Static HTML served by the Go backend (embedded via go:embed).
// A small client script calls /health to prove the frontend can talk to the API.
const title = 'Almanac';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root { color-scheme: light dark; }
      body {
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        max-width: 42rem;
        margin: 4rem auto;
        padding: 0 1.5rem;
        line-height: 1.6;
      }
      h1 { font-size: 2rem; margin-bottom: 0.25rem; }
      .subtitle { color: #888; margin-top: 0; }
      .card {
        border: 1px solid #8883;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin-top: 2rem;
      }
      .status { font-family: ui-monospace, "Cascadia Code", monospace; }
      .ok { color: #16a34a; }
      .err { color: #dc2626; }
    </style>
  </head>
  <body>
    <h1>📖 Almanac</h1>
    <p class="subtitle">自托管个人平台 · 博客 / 日记 / 记账本</p>

    <div class="card">
      <strong>后端状态</strong>
      <p class="status" id="health">检测中… <span aria-hidden="true">⏳</span></p>
    </div>

    <script>
      const el = document.getElementById('health');
      fetch('/health')
        .then((r) => r.json())
        .then((d) => {
          el.className = 'status ok';
          el.textContent = `✅ ${d.service} · ${d.status} · ${d.time}`;
        })
        .catch((e) => {
          el.className = 'status err';
          el.textContent = `❌ 无法连接后端: ${e}`;
        });
    </script>
  </body>
</html>
