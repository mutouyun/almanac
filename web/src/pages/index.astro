---
// Almanac entry portal.
// Pure client-side router: probes /api/whoami and forwards to /dashboard when
// logged in, otherwise to /login. Served as static HTML embedded via go:embed.
const title = 'Almanac';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root { color-scheme: light dark; }
      body {
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        display: flex;
        min-height: 100vh;
        margin: 0;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 0.75rem;
        color: #888;
      }
      .brand { font-size: 1.5rem; color: inherit; }
      .hint { font-size: 0.9rem; }
      .fallback { display: none; }
      .fallback a { color: #2563eb; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="brand">📖 Almanac</div>
    <p class="hint" id="hint">正在进入…</p>
    <p class="fallback" id="fallback">
      <a href="/login">前往登录</a>
    </p>

    <script>
      // Probe session state, then forward. Fall back to a manual link if the
      // probe fails (e.g. backend unreachable).
      fetch('/api/whoami')
        .then((r) => {
          window.location.replace(r.ok ? '/dashboard' : '/login');
        })
        .catch(() => {
          document.getElementById('hint').textContent = '无法连接服务器';
          document.getElementById('fallback').style.display = 'block';
        });
    </script>
  </body>
</html>
