---
// Almanac Ledger - full CRUD entry management with pagination
import Sidebar from '../components/Sidebar.astro';
const title = '账本明细 · Almanac';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lucide-static@0.400.0/font/lucide.min.css" />
    <style>
      @font-face {
        font-family: 'Geist';
        src: url('https://cdn.jsdelivr.net/gh/vercel/geist-font@1.0.0/fonts/geist-sans/Geist-Regular.woff2') format('woff2');
      }
      body { font-family: 'Geist', system-ui, -apple-system, sans-serif; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen flex">
    <Sidebar activePage="ledger" />

    <main class="flex-1 ml-64 p-8 max-w-5xl">
      <!-- Header -->
      <header class="flex justify-between items-end mb-8">
        <div>
          <h1 class="text-3xl font-bold text-slate-800 tracking-tight">账本明细</h1>
          <p class="text-slate-500 mt-1">在这里手动记账，管理所有流水。</p>
        </div>
        <button id="btn-new" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl font-medium shadow-sm shadow-blue-200 transition-all flex items-center gap-2">
          <i class="lucide-plus w-4 h-4"></i>
          <span>手动记账</span>
        </button>
      </header>

      <!-- Entries table -->
      <section class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div id="entries-loading" class="p-12 text-center text-slate-400">
          <div class="animate-pulse flex flex-col items-center">
            <div class="h-8 w-8 bg-slate-100 rounded-full mb-3"></div>
            <div class="h-2 w-24 bg-slate-100 rounded"></div>
          </div>
        </div>

        <div id="entries-empty" class="p-16 text-center text-slate-400" hidden>
          <i class="lucide-inbox w-10 h-10 mx-auto mb-3 block"></i>
          <p class="text-sm">还没有任何账目，点右上角开始记账吧。</p>
        </div>

        <div id="entries-list" class="divide-y divide-slate-50" hidden>
          <!-- Rows injected by JS -->
        </div>

        <!-- Pagination footer -->
        <div id="pager" class="px-6 py-3 bg-slate-50 border-t border-slate-100 flex items-center justify-between" hidden>
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <span>每页</span>
            <select id="page-size" class="bg-white border border-slate-200 rounded-lg px-2 py-1 outline-none focus:border-blue-300">
              <option value="20">20</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>
            <span id="pager-total"></span>
          </div>
          <div class="flex items-center gap-2">
            <button id="page-prev" class="px-3 py-1.5 rounded-lg border border-slate-200 text-sm text-slate-600 hover:bg-white disabled:opacity-40 disabled:cursor-not-allowed transition-all">上一页</button>
            <span id="page-info" class="text-xs text-slate-500 min-w-[4rem] text-center"></span>
            <button id="page-next" class="px-3 py-1.5 rounded-lg border border-slate-200 text-sm text-slate-600 hover:bg-white disabled:opacity-40 disabled:cursor-not-allowed transition-all">下一页</button>
          </div>
        </div>
      </section>

      <!-- Create/Edit Modal -->
      <div id="modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 items-center justify-center p-4" hidden>
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
          <div class="flex justify-between items-center mb-5">
            <h3 id="modal-title" class="text-lg font-bold text-slate-800">手动记账</h3>
            <button id="modal-close" class="text-slate-400 hover:text-slate-600"><i class="lucide-x w-5 h-5"></i></button>
          </div>
          <div class="space-y-4">
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">金额（元）</label>
              <input id="f-amount" type="number" step="0.01" min="0" placeholder="0.00" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300" />
            </div>
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">摘要 / 类型</label>
              <input id="f-rawtype" type="text" placeholder="如：午餐、公司工资" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300" />
            </div>
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">发生时间</label>
              <input id="f-time" type="datetime-local" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300" />
            </div>
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">分类（决定收支方向，可留空）</label>
              <select id="f-category" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300"></select>
            </div>
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">备注（可选）</label>
              <textarea id="f-note" rows="2" placeholder="补充说明" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300 resize-none"></textarea>
            </div>
            <p id="modal-msg" class="text-center text-xs text-rose-500 min-h-[1em]"></p>
            <div class="flex gap-3 pt-1">
              <button id="modal-cancel" class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-medium rounded-xl transition-all">取消</button>
              <button id="modal-save" class="flex-1 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl transition-all">保存</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Delete confirm -->
      <div id="del-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 items-center justify-center p-4" hidden>
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-rose-50 text-rose-500 flex items-center justify-center mx-auto mb-4">
            <i class="lucide-trash-2 w-6 h-6"></i>
          </div>
          <h3 class="text-lg font-bold text-slate-800 mb-2">确认删除？</h3>
          <p class="text-sm text-slate-500 mb-5">该账目将从列表和汇总中移除。</p>
          <div class="flex gap-3">
            <button id="del-cancel" class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-medium rounded-xl transition-all">取消</button>
            <button id="del-confirm" class="flex-1 py-2 bg-rose-600 hover:bg-rose-700 text-white text-sm font-bold rounded-xl transition-all">删除</button>
          </div>
        </div>
      </div>
    </main>

    <script>
      // ---- State ----
      let pageSize = 20;
      let offset = 0;
      let total = 0;
      let cats = [];        // flat category list
      let catsExpense = [];
      let catsIncome = [];
      let editingId = null; // null = create mode
      let deletingId = null;

      // Auth gate + initial load.
      fetch('/api/whoami')
        .then(r => { if (!r.ok) throw new Error(); return r.json(); })
        .then(() => loadCategories().then(loadEntries))
        .catch(() => window.location.href = '/login');

      // ---- Categories ----
      function treeOrder(list) {
        const childrenOf = new Map();
        for (const c of list) {
          const key = c.parent_id == null ? 0 : c.parent_id;
          if (!childrenOf.has(key)) childrenOf.set(key, []);
          childrenOf.get(key).push(c);
        }
        const ordered = [];
        const walk = (p) => { (childrenOf.get(p) || []).forEach(c => { ordered.push(c); walk(c.id); }); };
        walk(0); return ordered;
      }

      async function loadCategories() {
        const res = await fetch('/api/categories');
        const data = await res.json();
        cats = data.categories || [];
        catsExpense = treeOrder(cats.filter(c => c.direction === -1));
        catsIncome = treeOrder(cats.filter(c => c.direction === 1));
      }

      // catOptions builds the category <select> markup grouped by direction so
      // the user can pick either an expense or income category (or none).
      function catOptions(currentId) {
        let opts = `<option value="" ${!currentId ? 'selected' : ''}>\u672a\u5206\u7c7b\uff08\u5f85\u5206\u7c7b\uff09</option>`;
        const group = (label, list) => {
          if (!list.length) return '';
          let inner = '';
          list.forEach(c => {
            const sel = c.id === currentId ? 'selected' : '';
            const indent = c.level > 1 ? '\u3000'.repeat(c.level - 1) + '\u2514 ' : '';
            inner += `<option value="${c.id}" ${sel}>${indent}${c.name}</option>`;
          });
          return `<optgroup label="${label}">${inner}</optgroup>`;
        };
        opts += group('\u652f\u51fa', catsExpense);
        opts += group('\u6536\u5165', catsIncome);
        return opts;
      }

      // ---- Escaping (user text goes into innerHTML) ----
      function esc(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }
      const fmtYuan = (cents) => '\u00a5' + (Math.abs(cents) / 100).toFixed(2);
      // ---- Entries list + pagination ----
      const elLoading = document.getElementById('entries-loading');
      const elEmpty = document.getElementById('entries-empty');
      const elList = document.getElementById('entries-list');
      const elPager = document.getElementById('pager');

      async function loadEntries() {
        elLoading.hidden = false;
        elList.hidden = true;
        elEmpty.hidden = true;
        elPager.hidden = true;
        try {
          const res = await fetch(`/api/entries?limit=${pageSize}&offset=${offset}`);
          const data = await res.json();
          total = data.total;
          elLoading.hidden = true;

          if (!data.entries.length) {
            // If we paged past the end (e.g. after deleting), step back a page.
            if (offset > 0 && total > 0) { offset = Math.max(0, offset - pageSize); return loadEntries(); }
            elEmpty.hidden = false;
            return;
          }
          elList.hidden = false;
          elPager.hidden = false;
          rowCache = data.entries;
          elList.innerHTML = data.entries.map(renderRow).join('');
          bindRowActions();
          renderPager();
        } catch (e) {
          elLoading.textContent = '\u274c \u52a0\u8f7d\u5931\u8d25';
        }
      }

      function renderRow(e) {
        // Amounts unsigned; direction from assigned category (1/-1/0=待分类).
        const dir = e.direction || 0;
        const isExpense = dir === -1, isIncome = dir === 1;
        const amtColor = isExpense ? 'text-rose-500' : (isIncome ? 'text-emerald-500' : 'text-slate-400');
        const sign = isExpense ? '-' : (isIncome ? '+' : '');
        const icon = isExpense ? 'arrow-up-right' : (isIncome ? 'arrow-down-left' : 'help-circle');
        const bg = !e.category_id ? 'bg-amber-50/30' : 'hover:bg-slate-50';
        const srcBadge = e.source === 'manual'
          ? '<span class="px-1.5 py-0.5 bg-blue-50 text-blue-500 text-[10px] font-bold rounded">\u624b\u52a8</span>'
          : '';
        return `
          <div class="px-6 py-4 flex items-center gap-4 transition-colors ${bg}">
            <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400 shrink-0">
              <i class="lucide-${icon} w-5 h-5"></i>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-bold text-slate-700 truncate">${esc(e.raw_type)}</span>
                ${srcBadge}
                ${!e.category_id ? '<span class="px-1.5 py-0.5 bg-amber-100 text-amber-600 text-[10px] font-bold rounded">\u5f85\u5206\u7c7b</span>' : ''}
              </div>
              <div class="flex items-center gap-2 text-xs text-slate-400 mt-0.5">
                <span>${esc(e.record_time)}</span>
                ${e.category_path ? `<span class="opacity-50">/</span><span>${esc(e.category_path)}</span>` : ''}
                ${e.note ? `<span class="opacity-50">\u00b7</span><span class="truncate">${esc(e.note)}</span>` : ''}
              </div>
            </div>
            <div class="font-bold ${amtColor} shrink-0">${sign}${fmtYuan(e.amount_cents)}</div>
            <div class="flex items-center gap-1 shrink-0">
              <button class="row-edit inline-flex items-center gap-1 px-2.5 py-1.5 text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg text-xs font-medium transition-all" data-id="${e.id}" title="\u7f16\u8f91"><i class="lucide-pencil w-3.5 h-3.5"></i><span>\u7f16\u8f91</span></button>
              <button class="row-del inline-flex items-center gap-1 px-2.5 py-1.5 text-rose-600 bg-rose-50 hover:bg-rose-100 rounded-lg text-xs font-medium transition-all" data-id="${e.id}" title="\u5220\u9664"><i class="lucide-trash-2 w-3.5 h-3.5"></i><span>\u5220\u9664</span></button>
            </div>
          </div>`;
      }

      // rowCache holds the current page's entries for edit prefill.
      let rowCache = [];
      function bindRowActions() {
        document.querySelectorAll('.row-edit').forEach(b => {
          b.onclick = () => openEdit(Number(b.dataset.id));
        });
        document.querySelectorAll('.row-del').forEach(b => {
          b.onclick = () => openDelete(Number(b.dataset.id));
        });
      }

      function renderPager() {
        const from = offset + 1;
        const to = Math.min(offset + pageSize, total);
        document.getElementById('pager-total').textContent = `\uff0c\u5171 ${total} \u6761`;
        document.getElementById('page-info').textContent = `${from}-${to}`;
        document.getElementById('page-prev').disabled = offset === 0;
        document.getElementById('page-next').disabled = to >= total;
      }

      document.getElementById('page-prev').onclick = () => { if (offset > 0) { offset -= pageSize; loadEntries(); } };
      document.getElementById('page-next').onclick = () => { if (offset + pageSize < total) { offset += pageSize; loadEntries(); } };
      document.getElementById('page-size').onchange = (e) => { pageSize = Number(e.target.value); offset = 0; loadEntries(); };
      // ---- Modal (create / edit) ----
      const modal = document.getElementById('modal');
      const fAmount = document.getElementById('f-amount');
      const fRawType = document.getElementById('f-rawtype');
      const fTime = document.getElementById('f-time');
      const fCategory = document.getElementById('f-category');
      const fNote = document.getElementById('f-note');
      const modalMsg = document.getElementById('modal-msg');

      function showModal(el) { el.hidden = false; el.classList.add('flex'); }
      function hideModal(el) { el.hidden = true; el.classList.remove('flex'); }

      // localNowValue returns the current wall-clock as a datetime-local value
      // ("YYYY-MM-DDTHH:mm") in the browser's local time.
      function localNowValue() {
        const d = new Date();
        const pad = (n) => String(n).padStart(2, '0');
        return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
      }
      // recordTimeToInput converts a stored "YYYY-MM-DD HH:mm" to the
      // datetime-local input value ("YYYY-MM-DDTHH:mm").
      function recordTimeToInput(rt) {
        return rt && rt.length >= 16 ? rt.slice(0, 16).replace(' ', 'T') : localNowValue();
      }

      function openCreate() {
        editingId = null;
        document.getElementById('modal-title').textContent = '\u624b\u52a8\u8bb0\u8d26';
        fAmount.value = '';
        fRawType.value = '';
        fTime.value = localNowValue();
        fCategory.innerHTML = catOptions(null);
        fNote.value = '';
        modalMsg.textContent = '';
        showModal(modal);
        fAmount.focus();
      }

      function openEdit(id) {
        const e = rowCache.find(x => x.id === id);
        if (!e) return;
        editingId = id;
        document.getElementById('modal-title').textContent = '\u7f16\u8f91\u8d26\u76ee';
        fAmount.value = (e.amount_cents / 100).toFixed(2);
        fRawType.value = e.raw_type;
        fTime.value = recordTimeToInput(e.record_time);
        fCategory.innerHTML = catOptions(e.category_id);
        fNote.value = e.note || '';
        modalMsg.textContent = '';
        showModal(modal);
        fAmount.focus();
      }

      document.getElementById('btn-new').onclick = openCreate;
      document.getElementById('modal-close').onclick = () => hideModal(modal);
      document.getElementById('modal-cancel').onclick = () => hideModal(modal);

      document.getElementById('modal-save').onclick = async () => {
        const amount = parseFloat(fAmount.value);
        if (!(amount > 0)) { modalMsg.textContent = '\u91d1\u989d\u5fc5\u987b\u5927\u4e8e 0'; return; }
        if (!fRawType.value.trim()) { modalMsg.textContent = '\u8bf7\u586b\u5199\u6458\u8981'; return; }
        if (!fTime.value) { modalMsg.textContent = '\u8bf7\u9009\u62e9\u65f6\u95f4'; return; }
        // datetime-local -> "YYYY-MM-DD HH:mm" (server normalizes anyway).
        const recordTime = fTime.value.replace('T', ' ');
        const body = {
          amount: String(amount),
          raw_type: fRawType.value.trim(),
          record_time: recordTime,
          note: fNote.value.trim(),
          category_id: fCategory.value ? Number(fCategory.value) : null,
        };
        const save = document.getElementById('modal-save');
        save.disabled = true;
        try {
          const url = editingId ? `/api/entries/${editingId}` : '/api/entries';
          const method = editingId ? 'PUT' : 'POST';
          const res = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (!res.ok) {
            const d = await res.json().catch(() => ({}));
            modalMsg.textContent = '\u274c ' + (d.error || '\u4fdd\u5b58\u5931\u8d25');
            return;
          }
          hideModal(modal);
          if (!editingId) offset = 0; // jump to newest page after create
          loadEntries();
        } finally {
          save.disabled = false;
        }
      };

      // ---- Delete ----
      const delModal = document.getElementById('del-modal');
      function openDelete(id) { deletingId = id; showModal(delModal); }
      document.getElementById('del-cancel').onclick = () => hideModal(delModal);
      document.getElementById('del-confirm').onclick = async () => {
        if (!deletingId) return;
        const btn = document.getElementById('del-confirm');
        btn.disabled = true;
        try {
          await fetch(`/api/entries/${deletingId}`, { method: 'DELETE' });
          hideModal(delModal);
          deletingId = null;
          loadEntries();
        } finally {
          btn.disabled = false;
        }
      };

      // Close modals on backdrop click.
      modal.onclick = (e) => { if (e.target === modal) hideModal(modal); };
      delModal.onclick = (e) => { if (e.target === delModal) hideModal(delModal); };
    </script>
  </body>
</html>
