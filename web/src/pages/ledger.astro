---
// Almanac Ledger - full CRUD entry management with pagination
import Sidebar from '../components/Sidebar.astro';
const title = '账本明细 · Almanac';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline src="https://cdn.jsdelivr.net/npm/lucide@0.400.0/dist/umd/lucide.min.js"></script>
    <style>
      @font-face {
        font-family: 'Geist';
        src: url('https://cdn.jsdelivr.net/gh/vercel/geist-font@1.0.0/fonts/geist-sans/Geist-Regular.woff2') format('woff2');
      }
      body { font-family: 'Geist', system-ui, -apple-system, sans-serif; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen flex">
    <Sidebar activePage="ledger" />

    <main class="flex-1 ml-64 p-8">
      <div class="mx-auto max-w-7xl">
      <!-- Header -->
      <header class="flex justify-between items-center mb-8">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center shrink-0">
            <i data-lucide="book-text" class="w-6 h-6"></i>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-slate-800 tracking-tight">账本明细</h1>
            <p class="text-slate-500 text-sm mt-0.5">在这里手动记账，管理所有流水。</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <button id="btn-batch" class="bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 px-4 py-2 rounded-xl font-medium shadow-sm transition-all flex items-center gap-2">
            <i data-lucide="list-checks" class="w-4 h-4"></i>
            <span>批量操作</span>
          </button>
          <button id="btn-import" class="bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 px-4 py-2 rounded-xl font-medium shadow-sm transition-all flex items-center gap-2">
            <i data-lucide="upload" class="w-4 h-4"></i>
            <span>导入 CSV</span>
          </button>
          <button id="btn-new" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl font-medium shadow-sm shadow-blue-200 transition-all flex items-center gap-2">
            <i data-lucide="plus" class="w-4 h-4"></i>
            <span>手动记账</span>
          </button>
        </div>
      </header>

      <!-- Filter bar -->
      <section class="bg-white rounded-2xl border border-slate-200 shadow-sm p-4 mb-6">
        <div class="flex flex-wrap items-end gap-3">
          <!-- Direction segmented buttons -->
          <div>
            <label class="text-[11px] font-medium text-slate-400 mb-1 block">方向</label>
            <div id="flt-dir" class="inline-flex rounded-xl bg-slate-100 p-0.5 text-sm">
              <button data-dir="" class="flt-dir-btn px-3 py-1.5 rounded-lg font-medium transition-all bg-white text-slate-700 shadow-sm">全部</button>
              <button data-dir="expense" class="flt-dir-btn px-3 py-1.5 rounded-lg font-medium transition-all text-slate-500">支出</button>
              <button data-dir="income" class="flt-dir-btn px-3 py-1.5 rounded-lg font-medium transition-all text-slate-500">收入</button>
              <button data-dir="unclassified" class="flt-dir-btn px-3 py-1.5 rounded-lg font-medium transition-all text-slate-500">待分类</button>
            </div>
          </div>
          <!-- Category -->
          <div>
            <label class="text-[11px] font-medium text-slate-400 mb-1 block">分类</label>
            <select id="flt-cat" class="bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5 text-sm outline-none focus:border-blue-300 min-w-[8rem]"></select>
          </div>
          <!-- Keyword -->
          <div class="flex-1 min-w-[10rem]">
            <label class="text-[11px] font-medium text-slate-400 mb-1 block">关键词</label>
            <input id="flt-kw" type="text" placeholder="摘要或备注…" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5 text-sm outline-none focus:border-blue-300" />
          </div>
          <button id="flt-reset" class="px-3 py-1.5 rounded-xl border border-slate-200 text-sm text-slate-500 hover:bg-slate-50 transition-all">重置</button>
        </div>
        <div class="flex flex-wrap items-end gap-3 mt-3">
          <!-- Time range -->
          <div>
            <label class="text-[11px] font-medium text-slate-400 mb-1 block">开始日期</label>
            <input id="flt-start" type="date" class="bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5 text-sm outline-none focus:border-blue-300" />
          </div>
          <div>
            <label class="text-[11px] font-medium text-slate-400 mb-1 block">结束日期</label>
            <input id="flt-end" type="date" class="bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5 text-sm outline-none focus:border-blue-300" />
          </div>
          <!-- Amount range (yuan) -->
          <div>
            <label class="text-[11px] font-medium text-slate-400 mb-1 block">金额下限（元）</label>
            <input id="flt-min" type="number" step="0.01" min="0" placeholder="0.00" class="w-28 bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5 text-sm outline-none focus:border-blue-300" />
          </div>
          <div>
            <label class="text-[11px] font-medium text-slate-400 mb-1 block">金额上限（元）</label>
            <input id="flt-max" type="number" step="0.01" min="0" placeholder="不限" class="w-28 bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5 text-sm outline-none focus:border-blue-300" />
          </div>
        </div>
      </section>

      <!-- Select-all bar (only shown in selection mode) -->
      <div id="sel-bar" class="bg-blue-50 border border-blue-200 rounded-2xl px-4 py-3 mb-4 flex items-center justify-between" hidden>
        <label class="flex items-center gap-2 text-sm font-medium text-slate-700 cursor-pointer">
          <input id="sel-all" type="checkbox" class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
          <span>全选本页</span>
        </label>
        <div class="flex items-center gap-3">
          <span id="sel-summary" class="text-sm text-slate-500">已选 0 笔</span>
          <button id="sel-exit" class="px-3 py-1.5 rounded-lg border border-slate-200 bg-white text-sm text-slate-500 hover:bg-slate-50 transition-all">退出选择</button>
        </div>
      </div>

      <!-- Entries table -->
      <section class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div id="entries-loading" class="p-12 text-center text-slate-400">
          <div class="animate-pulse flex flex-col items-center">
            <div class="h-8 w-8 bg-slate-100 rounded-full mb-3"></div>
            <div class="h-2 w-24 bg-slate-100 rounded"></div>
          </div>
        </div>

        <div id="entries-empty" class="p-16 text-center text-slate-400" hidden>
          <i data-lucide="inbox" class="w-10 h-10 mx-auto mb-3 block"></i>
          <p class="text-sm">还没有任何账目，点右上角开始记账吧。</p>
        </div>

        <div id="entries-list" class="divide-y divide-slate-50" hidden>
          <!-- Rows injected by JS -->
        </div>

        <!-- Pagination footer -->
        <div id="pager" class="px-6 py-3 bg-slate-50 border-t border-slate-100 flex items-center justify-between" hidden>
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <span>每页</span>
            <select id="page-size" class="bg-white border border-slate-200 rounded-lg px-2 py-1 outline-none focus:border-blue-300">
              <option value="20">20</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>
            <span id="pager-total"></span>
          </div>
          <div class="flex items-center gap-2">
            <button id="page-prev" class="px-3 py-1.5 rounded-lg border border-slate-200 text-sm text-slate-600 hover:bg-white disabled:opacity-40 disabled:cursor-not-allowed transition-all">上一页</button>
            <span id="page-info" class="text-xs text-slate-500 min-w-[4rem] text-center"></span>
            <button id="page-next" class="px-3 py-1.5 rounded-lg border border-slate-200 text-sm text-slate-600 hover:bg-white disabled:opacity-40 disabled:cursor-not-allowed transition-all">下一页</button>
          </div>
        </div>
      </section>

      <!-- Floating batch action bar (selection mode, when >=1 selected) -->
      <div id="batch-bar" class="fixed bottom-6 left-1/2 -translate-x-1/2 ml-32 z-30 bg-white rounded-2xl shadow-xl border border-slate-200 px-5 py-3 items-center gap-4" hidden>
        <span id="batch-count" class="text-sm font-medium text-slate-700">已选 0 笔 · 合计 ¥0.00</span>
        <div class="flex items-center gap-2">
          <button id="batch-recat" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-all disabled:opacity-40">
            <i data-lucide="folder-tree" class="w-4 h-4"></i><span>改分类</span>
          </button>
          <button id="batch-del" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-rose-600 hover:bg-rose-700 text-white text-sm font-medium rounded-lg transition-all disabled:opacity-40">
            <i data-lucide="trash-2" class="w-4 h-4"></i><span>删除</span>
          </button>
        </div>
      </div>

      <!-- Batch recategorize modal -->
      <div id="brecat-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 items-center justify-center p-4" hidden>
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
          <div class="flex justify-between items-center mb-5">
            <h3 class="text-lg font-bold text-slate-800">批量改分类</h3>
            <button id="brecat-close" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
          </div>
          <div class="space-y-4">
            <p class="text-sm text-slate-500">将为 <span id="brecat-count" class="font-bold text-slate-700">0</span> 笔账目设置新分类。</p>
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">目标分类</label>
              <select id="brecat-cat" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300"></select>
            </div>
            <p class="text-xs text-amber-600 bg-amber-50 rounded-lg px-3 py-2">⚠️ 方向将按新分类自动调整，跨方向改分类会翻转收/支属性，可能影响本月汇总。</p>
            <p id="brecat-msg" class="text-center text-xs text-rose-500 min-h-[1em]"></p>
            <div class="flex gap-3 pt-1">
              <button id="brecat-cancel" class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-medium rounded-xl transition-all">取消</button>
              <button id="brecat-confirm" class="flex-1 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl transition-all">确认</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Batch delete confirm modal -->
      <div id="bdel-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 items-center justify-center p-4" hidden>
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-rose-50 text-rose-500 flex items-center justify-center mx-auto mb-4">
            <i data-lucide="trash-2" class="w-6 h-6"></i>
          </div>
          <h3 class="text-lg font-bold text-slate-800 mb-2">确认批量删除？</h3>
          <p id="bdel-desc" class="text-sm text-slate-500 mb-5">将删除 0 笔，合计 ¥0.00，不可恢复。</p>
          <p id="bdel-msg" class="text-center text-xs text-rose-500 min-h-[1em] mb-2"></p>
          <div class="flex gap-3">
            <button id="bdel-cancel" class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-medium rounded-xl transition-all">取消</button>
            <button id="bdel-confirm" class="flex-1 py-2 bg-rose-600 hover:bg-rose-700 text-white text-sm font-bold rounded-xl transition-all">删除</button>
          </div>
        </div>
      </div>

      <!-- Create/Edit Modal -->
      <div id="modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 items-center justify-center p-4" hidden>
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
          <div class="flex justify-between items-center mb-5">
            <h3 id="modal-title" class="text-lg font-bold text-slate-800">手动记账</h3>
            <button id="modal-close" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
          </div>
          <div class="space-y-4">
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">金额（元）</label>
              <input id="f-amount" type="number" step="0.01" min="0" placeholder="0.00" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300" />
            </div>
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">摘要 / 类型（可留空，默认用分类名）</label>
              <input id="f-rawtype" type="text" placeholder="如：午餐、公司工资" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300" />
            </div>
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">发生时间</label>
              <input id="f-time" type="datetime-local" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300" />
            </div>
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">分类（决定收支方向，可留空）</label>
              <select id="f-category" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300"></select>
            </div>
            <div>
              <label class="text-xs font-medium text-slate-500 mb-1 block">备注（可选）</label>
              <textarea id="f-note" rows="2" placeholder="补充说明" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-300 resize-none"></textarea>
            </div>
            <p id="modal-msg" class="text-center text-xs text-rose-500 min-h-[1em]"></p>
            <div class="flex gap-3 pt-1">
              <button id="modal-cancel" class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-medium rounded-xl transition-all">取消</button>
              <button id="modal-save" class="flex-1 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl transition-all">保存</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Delete confirm -->
      <div id="del-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 items-center justify-center p-4" hidden>
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-rose-50 text-rose-500 flex items-center justify-center mx-auto mb-4">
            <i data-lucide="trash-2" class="w-6 h-6"></i>
          </div>
          <h3 class="text-lg font-bold text-slate-800 mb-2">确认删除？</h3>
          <p class="text-sm text-slate-500 mb-5">该账目将从列表和汇总中移除。</p>
          <div class="flex gap-3">
            <button id="del-cancel" class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-medium rounded-xl transition-all">取消</button>
            <button id="del-confirm" class="flex-1 py-2 bg-rose-600 hover:bg-rose-700 text-white text-sm font-bold rounded-xl transition-all">删除</button>
          </div>
        </div>
      </div>

      <!-- CSV Import Modal -->
      <div id="import-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 items-center justify-center p-4" hidden>
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl p-6">
          <div class="flex justify-between items-center mb-5">
            <h3 class="text-lg font-bold text-slate-800">导入 CSV</h3>
            <button id="import-close" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
          </div>

          <!-- Step 1: Upload -->
          <div id="import-step1" class="space-y-4">
            <div class="border-2 border-dashed border-slate-200 rounded-xl p-8 text-center hover:border-blue-300 transition-all">
              <i data-lucide="file-text" class="w-12 h-12 text-slate-300 mx-auto mb-3"></i>
              <p class="text-sm text-slate-600 mb-1">支持「毛线记账本」App 导出的 CSV 文件</p>
              <p class="text-xs text-slate-400 mb-4">预览后确认，不会立即导入</p>
              <input id="csv-file" type="file" accept=".csv" class="hidden" />
              <button id="csv-pick" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-xl font-medium shadow-sm transition-all">选择文件</button>
            </div>
            <p id="import-msg1" class="text-center text-xs text-rose-500 min-h-[1em]"></p>
          </div>

          <!-- Step 2: Preview & Confirm -->
          <div id="import-step2" class="space-y-4" hidden>
            <div class="bg-slate-50 rounded-xl p-4 space-y-2">
              <div class="flex justify-between text-sm">
                <span class="text-slate-500">总记录：</span>
                <span id="prev-total" class="font-bold text-slate-700">0</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-slate-500">已归类：</span>
                <span id="prev-classified" class="font-semibold text-emerald-600">0</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-slate-500">待分类：</span>
                <span id="prev-unclassified" class="font-semibold text-amber-600">0</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-slate-500">跳过（格式错误）：</span>
                <span id="prev-skipped" class="font-semibold text-slate-400">0</span>
              </div>
              <div class="border-t border-slate-200 my-2 pt-2 space-y-1">
                <div class="flex justify-between text-sm">
                  <span class="text-slate-500">收入总计：</span>
                  <span id="prev-income" class="font-bold text-emerald-600">0</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-slate-500">支出总计：</span>
                  <span id="prev-expense" class="font-bold text-rose-600">0</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-slate-500">待分类金额：</span>
                  <span id="prev-unclass-amt" class="font-semibold text-slate-400">0</span>
                </div>
              </div>
            </div>
            <div class="max-h-60 overflow-y-auto bg-slate-50 rounded-xl p-3">
              <p class="text-xs font-medium text-slate-400 mb-2">前 10 条示例：</p>
              <div id="prev-sample" class="space-y-1 text-xs text-slate-600"></div>
            </div>
            <p id="import-msg2" class="text-center text-xs text-rose-500 min-h-[1em]"></p>
            <div class="flex gap-3 pt-1">
              <button id="import-back" class="flex-1 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm font-medium rounded-xl transition-all">返回</button>
              <button id="import-confirm" class="flex-1 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl transition-all">确认导入</button>
            </div>
          </div>
        </div>
      </div>
      </div>
    </main>

    <script>
      // ---- State ----
      let pageSize = 20;
      let offset = 0;
      let total = 0;
      let cats = [];        // flat category list
      let catsExpense = [];
      let catsIncome = [];
      let editingId = null; // null = create mode
      let deletingId = null;
      let selectMode = false;        // batch selection mode on/off
      const selected = new Set();    // selected entry ids (numbers)

      // Render static icons present in the initial markup.
      window.lucide?.createIcons();

      // Auth gate + initial load.
      fetch('/api/whoami')
        .then(r => { if (!r.ok) throw new Error(); return r.json(); })
        .then(() => loadCategories().then(() => { initFilters(); loadEntries(); }))
        .catch(() => window.location.href = '/login?expired=1');

      // ---- Categories ----
      function treeOrder(list) {
        const childrenOf = new Map();
        for (const c of list) {
          const key = c.parent_id == null ? 0 : c.parent_id;
          if (!childrenOf.has(key)) childrenOf.set(key, []);
          childrenOf.get(key).push(c);
        }
        const ordered = [];
        const walk = (p) => { (childrenOf.get(p) || []).forEach(c => { ordered.push(c); walk(c.id); }); };
        walk(0); return ordered;
      }

      async function loadCategories() {
        const res = await fetch('/api/categories');
        const data = await res.json();
        cats = data.categories || [];
        catsExpense = treeOrder(cats.filter(c => c.direction === -1));
        catsIncome = treeOrder(cats.filter(c => c.direction === 1));
      }

      // ---- Filter bar wiring ----
      // fltCatOptions builds the filter category dropdown (grouped, no
      // "unclassified" pseudo-option; blank = any category).
      function fltCatOptions() {
        let opts = `<option value="">\u5168\u90e8\u5206\u7c7b</option>`;
        const group = (label, list) => {
          if (!list.length) return '';
          let inner = '';
          list.forEach(c => {
            const indent = c.level > 1 ? '\u3000'.repeat(c.level - 1) + '\u2514 ' : '';
            inner += `<option value="${c.id}">${indent}${c.name}</option>`;
          });
          return `<optgroup label="${label}">${inner}</optgroup>`;
        };
        opts += group('\u652f\u51fa', catsExpense);
        opts += group('\u6536\u5165', catsIncome);
        return opts;
      }

      // applyFilter resets to page 1 and reloads with current filter state.
      function applyFilter() { offset = 0; loadEntries(); }

      let kwTimer = null;
      function initFilters() {
        document.getElementById('flt-cat').innerHTML = fltCatOptions();

        // Direction segmented buttons.
        document.querySelectorAll('.flt-dir-btn').forEach(b => {
          b.onclick = () => {
            filters.direction = b.dataset.dir;
            document.querySelectorAll('.flt-dir-btn').forEach(x => {
              const on = x === b;
              x.classList.toggle('bg-white', on);
              x.classList.toggle('text-slate-700', on);
              x.classList.toggle('shadow-sm', on);
              x.classList.toggle('text-slate-500', !on);
            });
            applyFilter();
          };
        });

        document.getElementById('flt-cat').onchange = (e) => { filters.category = e.target.value; applyFilter(); };
        document.getElementById('flt-start').onchange = (e) => { filters.start = e.target.value; applyFilter(); };
        document.getElementById('flt-end').onchange = (e) => { filters.end = e.target.value; applyFilter(); };
        document.getElementById('flt-min').onchange = (e) => { filters.min = e.target.value; applyFilter(); };
        document.getElementById('flt-max').onchange = (e) => { filters.max = e.target.value; applyFilter(); };
        // Keyword: 300ms debounce so we don't fire per keystroke.
        document.getElementById('flt-kw').oninput = (e) => {
          filters.q = e.target.value;
          clearTimeout(kwTimer);
          kwTimer = setTimeout(applyFilter, 300);
        };

        document.getElementById('flt-reset').onclick = () => {
          filters.direction = ''; filters.category = ''; filters.q = '';
          filters.start = ''; filters.end = ''; filters.min = ''; filters.max = '';
          document.getElementById('flt-cat').value = '';
          document.getElementById('flt-kw').value = '';
          document.getElementById('flt-start').value = '';
          document.getElementById('flt-end').value = '';
          document.getElementById('flt-min').value = '';
          document.getElementById('flt-max').value = '';
          document.querySelectorAll('.flt-dir-btn').forEach(x => {
            const on = x.dataset.dir === '';
            x.classList.toggle('bg-white', on);
            x.classList.toggle('text-slate-700', on);
            x.classList.toggle('shadow-sm', on);
            x.classList.toggle('text-slate-500', !on);
          });
          applyFilter();
        };
      }

      // catOptions builds the category <select> markup grouped by direction so
      // the user can pick either an expense or income category (or none).
      function catOptions(currentId) {
        let opts = `<option value="" ${!currentId ? 'selected' : ''}>\u672a\u5206\u7c7b\uff08\u5f85\u5206\u7c7b\uff09</option>`;
        const group = (label, list) => {
          if (!list.length) return '';
          let inner = '';
          list.forEach(c => {
            const sel = c.id === currentId ? 'selected' : '';
            const indent = c.level > 1 ? '\u3000'.repeat(c.level - 1) + '\u2514 ' : '';
            inner += `<option value="${c.id}" ${sel}>${indent}${c.name}</option>`;
          });
          return `<optgroup label="${label}">${inner}</optgroup>`;
        };
        opts += group('\u652f\u51fa', catsExpense);
        opts += group('\u6536\u5165', catsIncome);
        return opts;
      }

      // ---- Escaping (user text goes into innerHTML) ----
      function esc(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }
      const fmtYuan = (cents) => '\u00a5' + (Math.abs(cents) / 100).toFixed(2);

      // ---- Icon mapping (Lucide) ----
      // Each entry maps a set of keywords to a Lucide icon name. Matching is
      // substring-based against the category name first, then the raw_type
      // summary. First rule that matches wins, so order roughly by specificity.
      const ICON_RULES = [
        { icon: 'utensils',       kw: ['\u9910\u996e', '\u5403', '\u996d', '\u5348\u9910', '\u665a\u9910', '\u65e9\u9910', '\u5916\u5356', '\u7f8e\u98df', 'food', 'meal'] },
        { icon: 'coffee',         kw: ['\u5496\u5561', '\u5976\u8336', '\u996e\u6599', '\u661f\u5df4\u514b', 'coffee', 'tea'] },
        { icon: 'shopping-cart',  kw: ['\u8d2d\u7269', '\u8d85\u5e02', '\u91c7\u8d2d', '\u6dd8\u5b9d', '\u4eac\u4e1c', 'shopping'] },
        { icon: 'shopping-bag',   kw: ['\u670d\u88c5', '\u8863\u670d', '\u978b', '\u5305', '\u7f8e\u5986', '\u5316\u5986\u54c1'] },
        { icon: 'car',            kw: ['\u4ea4\u901a', '\u6253\u8f66', '\u6253\u7684', '\u51fa\u884c', '\u6c7d\u8f66', '\u52a0\u6cb9', '\u6cb9\u8d39', 'taxi', 'uber'] },
        { icon: 'bus',            kw: ['\u516c\u4ea4', '\u5730\u94c1', '\u5730\u94c1', '\u9ad8\u94c1', '\u706b\u8f66', '\u706b\u8f66\u7968', '\u5730\u94c1\u7968'] },
        { icon: 'plane',          kw: ['\u673a\u7968', '\u98de\u673a', '\u822a\u73ed', 'flight'] },
        { icon: 'home',           kw: ['\u623f\u79df', '\u623f\u8d37', '\u7269\u4e1a', '\u623f\u5b50', '\u79df\u91d1'] },
        { icon: 'zap',            kw: ['\u6c34\u7535', '\u7535\u8d39', '\u6c34\u8d39', '\u71c3\u6c14', '\u6c34\u7535\u7164'] },
        { icon: 'wifi',           kw: ['\u8bdd\u8d39', '\u7f51\u8d39', '\u5bbd\u5e26', '\u6d41\u91cf', '\u901a\u4fe1'] },
        { icon: 'smartphone',     kw: ['\u624b\u673a', '\u6570\u7801', '\u7535\u5b50\u4ea7\u54c1'] },
        { icon: 'gamepad-2',      kw: ['\u6e38\u620f', '\u5a31\u4e50', '\u5145\u503c'] },
        { icon: 'clapperboard',   kw: ['\u7535\u5f71', '\u770b\u7535\u5f71', 'ktv', '\u5a31\u4e50'] },
        { icon: 'heart-pulse',    kw: ['\u533b\u7597', '\u770b\u75c5', '\u533b\u9662', '\u836f', '\u4f53\u68c0', '\u5065\u5eb7'] },
        { icon: 'graduation-cap', kw: ['\u6559\u80b2', '\u5b66\u4e60', '\u57f9\u8bad', '\u5b66\u8d39', '\u4e66', '\u56fe\u4e66'] },
        { icon: 'baby',           kw: ['\u5b69\u5b50', '\u5a74\u513f', '\u5c0f\u5b69', '\u6bcd\u5a74'] },
        { icon: 'gift',           kw: ['\u793c\u7269', '\u793c\u91d1', '\u4eba\u60c5', '\u7ea2\u5305'] },
        { icon: 'paw-print',      kw: ['\u5ba0\u7269', '\u732b', '\u72d7'] },
        { icon: 'dumbbell',       kw: ['\u5065\u8eab', '\u8fd0\u52a8', '\u4f53\u80b2'] },
        { icon: 'briefcase',      kw: ['\u5de5\u8d44', '\u85aa\u8d44', '\u5de5\u4f5c', '\u5de5\u8d44\u6536\u5165', 'salary'] },
        { icon: 'trending-up',    kw: ['\u7406\u8d22', '\u6295\u8d44', '\u80a1\u7968', '\u57fa\u91d1', '\u6536\u76ca', '\u5229\u606f'] },
        { icon: 'award',          kw: ['\u5956\u91d1', '\u7ea2\u5229', '\u5956\u52b1', '\u63d0\u6210'] },
        { icon: 'landmark',       kw: ['\u94f6\u884c', '\u8f6c\u8d26', '\u50a8\u84c4'] },
        { icon: 'receipt',        kw: ['\u62a5\u9500', '\u53d1\u7968', '\u7a0e'] },
      ];

      // iconFor resolves the Lucide icon name for one entry. It scans category
      // name then raw_type against ICON_RULES; if nothing matches it falls back
      // to a direction glyph (income/expense/unclassified).
      function iconFor(e) {
        const hay = ((e.category_name || '') + ' ' + (e.category_path || '') + ' ' + (e.raw_type || '')).toLowerCase();
        for (const r of ICON_RULES) {
          if (r.kw.some(k => hay.includes(k.toLowerCase()))) return r.icon;
        }
        const dir = e.direction || 0;
        return dir === -1 ? 'arrow-up-right' : (dir === 1 ? 'arrow-down-left' : 'help-circle');
      }
      // ---- Entries list + pagination ----
      const elLoading = document.getElementById('entries-loading');
      const elEmpty = document.getElementById('entries-empty');
      const elList = document.getElementById('entries-list');
      const elPager = document.getElementById('pager');

      // ---- Filter state ----
      const filters = { direction: '', category: '', q: '', start: '', end: '', min: '', max: '' };

      // buildQuery assembles the /api/entries query string from pagination +
      // the active filters (only non-empty ones are sent).
      function buildQuery() {
        const p = new URLSearchParams();
        p.set('limit', pageSize);
        p.set('offset', offset);
        if (filters.direction) p.set('direction', filters.direction);
        if (filters.category) p.set('category', filters.category);
        if (filters.q.trim()) p.set('q', filters.q.trim());
        if (filters.start) p.set('start', filters.start + ' 00:00');
        if (filters.end) p.set('end', filters.end + ' 23:59');
        if (filters.min !== '') p.set('min', filters.min);
        if (filters.max !== '') p.set('max', filters.max);
        return p.toString();
      }

      async function loadEntries() {
        elLoading.hidden = false;
        elList.hidden = true;
        elEmpty.hidden = true;
        elPager.hidden = true;
        try {
          const res = await fetch(`/api/entries?${buildQuery()}`);
          const data = await res.json();
          total = data.total;
          elLoading.hidden = true;

          if (!data.entries.length) {
            // If we paged past the end (e.g. after deleting), step back a page.
            if (offset > 0 && total > 0) { offset = Math.max(0, offset - pageSize); return loadEntries(); }
            const active = filters.direction || filters.category || filters.q.trim() || filters.start || filters.end || filters.min !== '' || filters.max !== '';
            const msg = elEmpty.querySelector('p');
            if (msg) msg.textContent = active ? '\u6ca1\u6709\u7b26\u5408\u7b5b\u9009\u6761\u4ef6\u7684\u8d26\u76ee\u3002' : '\u8fd8\u6ca1\u6709\u4efb\u4f55\u8d26\u76ee\uff0c\u70b9\u53f3\u4e0a\u89d2\u5f00\u59cb\u8bb0\u8d26\u5427\u3002';
            elEmpty.hidden = false;
            return;
          }
          elList.hidden = false;
          elPager.hidden = false;
          rowCache = data.entries;
          elList.innerHTML = data.entries.map(renderRow).join('');
          window.lucide?.createIcons();
          bindRowActions();
          if (selectMode) syncSelectionUI();
          renderPager();
        } catch (e) {
          elLoading.textContent = '\u274c \u52a0\u8f7d\u5931\u8d25';
        }
      }

      function renderRow(e) {
        // Amounts unsigned; direction from assigned category (1/-1/0=待分类).
        const dir = e.direction || 0;
        const isExpense = dir === -1, isIncome = dir === 1;
        const amtColor = isExpense ? 'text-rose-500' : (isIncome ? 'text-emerald-500' : 'text-slate-400');
        const sign = isExpense ? '-' : (isIncome ? '+' : '');
        const icon = iconFor(e);
        const iconTint = isExpense ? 'bg-rose-50 text-rose-500' : (isIncome ? 'bg-emerald-50 text-emerald-500' : 'bg-slate-100 text-slate-400');
        const bg = !e.category_id ? 'bg-amber-50/30' : 'hover:bg-slate-50';
        const srcBadge = e.source === 'manual'
          ? '<span class="px-1.5 py-0.5 bg-blue-50 text-blue-500 text-[10px] font-bold rounded">\u624b\u52a8</span>'
          : '';
        return `
          <div class="px-6 py-4 flex items-center gap-4 transition-colors ${bg}">
            <input type="checkbox" class="row-check w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500 shrink-0 ${selectMode ? '' : 'hidden'}" data-id="${e.id}" ${selected.has(e.id) ? 'checked' : ''} />
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 ${iconTint}">
              <i data-lucide="${icon}" class="w-5 h-5"></i>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-bold text-slate-700 truncate">${esc(e.raw_type || e.category_name || '\u672a\u5206\u7c7b')}</span>
                ${srcBadge}
                ${!e.category_id ? '<span class="px-1.5 py-0.5 bg-amber-100 text-amber-600 text-[10px] font-bold rounded">\u5f85\u5206\u7c7b</span>' : ''}
              </div>
              <div class="flex items-center gap-2 text-xs text-slate-400 mt-0.5">
                <span>${esc(e.record_time)}</span>
                ${e.category_path ? `<span class="opacity-50">/</span><span>${esc(e.category_path)}</span>` : ''}
                ${e.note ? `<span class="opacity-50">\u00b7</span><span class="truncate">${esc(e.note)}</span>` : ''}
              </div>
            </div>
            <div class="font-bold ${amtColor} shrink-0">${sign}${fmtYuan(e.amount_cents)}</div>
            <div class="row-actions flex items-center gap-1 shrink-0 ${selectMode ? 'hidden' : ''}">
              <button class="row-edit inline-flex items-center gap-1 px-2.5 py-1.5 text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg text-xs font-medium transition-all" data-id="${e.id}" title="\u7f16\u8f91"><i data-lucide="pencil" class="w-3.5 h-3.5"></i><span>\u7f16\u8f91</span></button>
              <button class="row-del inline-flex items-center gap-1 px-2.5 py-1.5 text-rose-600 bg-rose-50 hover:bg-rose-100 rounded-lg text-xs font-medium transition-all" data-id="${e.id}" title="\u5220\u9664"><i data-lucide="trash-2" class="w-3.5 h-3.5"></i><span>\u5220\u9664</span></button>
            </div>
          </div>`;
      }

      // rowCache holds the current page's entries for edit prefill.
      let rowCache = [];
      function bindRowActions() {
        document.querySelectorAll('.row-edit').forEach(b => {
          b.onclick = () => openEdit(Number(b.dataset.id));
        });
        document.querySelectorAll('.row-del').forEach(b => {
          b.onclick = () => openDelete(Number(b.dataset.id));
        });
        document.querySelectorAll('.row-check').forEach(cb => {
          cb.onchange = () => {
            const id = Number(cb.dataset.id);
            if (cb.checked) selected.add(id); else selected.delete(id);
            syncSelectionUI();
          };
        });
      }

      // ---- Batch selection ----
      // syncSelectionUI refreshes the select-all checkbox, floating bar count
      // and total, and enables/disables the action buttons.
      function syncSelectionUI() {
        const ids = rowCache.map(e => e.id);
        const allChecked = ids.length > 0 && ids.every(id => selected.has(id));
        const selAll = document.getElementById('sel-all');
        if (selAll) {
          selAll.checked = allChecked;
          selAll.indeterminate = !allChecked && ids.some(id => selected.has(id));
        }
        const n = selected.size;
        // Sum signed amounts of selected rows currently on the page for the
        // confirm anchor (cross-page selection is not offered).
        let cents = 0;
        for (const e of rowCache) {
          if (!selected.has(e.id)) continue;
          const dir = e.direction || 0;
          // Classified rows sum signed (income +, expense -); unclassified
          // rows have no direction, so count their absolute magnitude.
          cents += dir === 1 ? e.amount_cents : (dir === -1 ? -e.amount_cents : e.amount_cents);
        }
        const sumText = (cents < 0 ? '-' : '') + fmtYuan(cents);
        document.getElementById('sel-summary').textContent = `已选 ${n} 笔`;
        document.getElementById('batch-count').textContent = `已选 ${n} 笔 · 合计 ${sumText}`;
        const bar = document.getElementById('batch-bar');
        bar.hidden = n === 0;
        if (n === 0) bar.classList.remove('flex'); else bar.classList.add('flex');
        document.getElementById('batch-recat').disabled = n === 0;
        document.getElementById('batch-del').disabled = n === 0;
      }

      // enterSelectMode / exitSelectMode toggle the row checkboxes + bars.
      function enterSelectMode() {
        selectMode = true;
        selected.clear();
        const selAll = document.getElementById('sel-all');
        if (selAll) { selAll.checked = false; selAll.indeterminate = false; }
        document.getElementById('sel-bar').hidden = false;
        loadEntries();
      }
      function exitSelectMode() {
        selectMode = false;
        selected.clear();
        const selAll = document.getElementById('sel-all');
        if (selAll) { selAll.checked = false; selAll.indeterminate = false; }
        document.getElementById('sel-bar').hidden = true;
        const bar = document.getElementById('batch-bar');
        bar.hidden = true; bar.classList.remove('flex');
        loadEntries();
      }

      document.getElementById('btn-batch').onclick = () => { selectMode ? exitSelectMode() : enterSelectMode(); };
      document.getElementById('sel-exit').onclick = exitSelectMode;
      document.getElementById('sel-all').onchange = (e) => {
        for (const row of rowCache) {
          if (e.target.checked) selected.add(row.id); else selected.delete(row.id);
        }
        document.querySelectorAll('.row-check').forEach(cb => { cb.checked = e.target.checked; });
        syncSelectionUI();
      };

      // ---- Batch recategorize ----
      const brecatModal = document.getElementById('brecat-modal');
      document.getElementById('batch-recat').onclick = () => {
        if (selected.size === 0) return;
        document.getElementById('brecat-count').textContent = selected.size;
        document.getElementById('brecat-cat').innerHTML = catOptions(null);
        document.getElementById('brecat-msg').textContent = '';
        showModal(brecatModal);
      };
      document.getElementById('brecat-close').onclick = () => hideModal(brecatModal);
      document.getElementById('brecat-cancel').onclick = () => hideModal(brecatModal);
      brecatModal.onclick = (e) => { if (e.target === brecatModal) hideModal(brecatModal); };
      document.getElementById('brecat-confirm').onclick = async () => {
        const catVal = document.getElementById('brecat-cat').value;
        const btn = document.getElementById('brecat-confirm');
        btn.disabled = true;
        try {
          const res = await fetch('/api/entries/batch/recategorize', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids: [...selected], category_id: catVal ? Number(catVal) : null }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) { document.getElementById('brecat-msg').textContent = '❌ ' + (data.error || '操作失败'); return; }
          hideModal(brecatModal);
          const skipped = (data.skipped && data.skipped.length) || 0;
          alert(`成功改 ${data.affected} 笔${skipped ? `，跳过 ${skipped} 笔` : ''}。`);
          exitSelectMode();
        } finally {
          btn.disabled = false;
        }
      };

      // ---- Batch delete ----
      const bdelModal = document.getElementById('bdel-modal');
      document.getElementById('batch-del').onclick = () => {
        if (selected.size === 0) return;
        let cents = 0;
        for (const e of rowCache) {
          if (!selected.has(e.id)) continue;
          const dir = e.direction || 0;
          cents += dir === 1 ? e.amount_cents : (dir === -1 ? -e.amount_cents : e.amount_cents);
        }
        const sumText = (cents < 0 ? '-' : '') + fmtYuan(cents);
        document.getElementById('bdel-desc').textContent = `将删除 ${selected.size} 笔，合计 ${sumText}，不可恢复。`;
        document.getElementById('bdel-msg').textContent = '';
        showModal(bdelModal);
      };
      document.getElementById('bdel-cancel').onclick = () => hideModal(bdelModal);
      bdelModal.onclick = (e) => { if (e.target === bdelModal) hideModal(bdelModal); };
      document.getElementById('bdel-confirm').onclick = async () => {
        const btn = document.getElementById('bdel-confirm');
        btn.disabled = true;
        try {
          const res = await fetch('/api/entries/batch/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids: [...selected] }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) { document.getElementById('bdel-msg').textContent = '❌ ' + (data.error || '删除失败'); return; }
          hideModal(bdelModal);
          const skipped = (data.skipped && data.skipped.length) || 0;
          alert(`已删除 ${data.affected} 笔${skipped ? `，跳过 ${skipped} 笔` : ''}。`);
          exitSelectMode();
        } finally {
          btn.disabled = false;
        }
      };

      function renderPager() {
        const from = offset + 1;
        const to = Math.min(offset + pageSize, total);
        document.getElementById('pager-total').textContent = `\uff0c\u5171 ${total} \u6761`;
        document.getElementById('page-info').textContent = `${from}-${to}`;
        document.getElementById('page-prev').disabled = offset === 0;
        document.getElementById('page-next').disabled = to >= total;
      }

      document.getElementById('page-prev').onclick = () => { if (offset > 0) { offset -= pageSize; loadEntries(); } };
      document.getElementById('page-next').onclick = () => { if (offset + pageSize < total) { offset += pageSize; loadEntries(); } };
      document.getElementById('page-size').onchange = (e) => { pageSize = Number(e.target.value); offset = 0; loadEntries(); };
      // ---- Modal (create / edit) ----
      const modal = document.getElementById('modal');
      const fAmount = document.getElementById('f-amount');
      const fRawType = document.getElementById('f-rawtype');
      const fTime = document.getElementById('f-time');
      const fCategory = document.getElementById('f-category');
      const fNote = document.getElementById('f-note');
      const modalMsg = document.getElementById('modal-msg');

      function showModal(el) { el.hidden = false; el.classList.add('flex'); }
      function hideModal(el) { el.hidden = true; el.classList.remove('flex'); }

      // localNowValue returns the current wall-clock as a datetime-local value
      // ("YYYY-MM-DDTHH:mm") in the browser's local time.
      function localNowValue() {
        const d = new Date();
        const pad = (n) => String(n).padStart(2, '0');
        return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
      }
      // recordTimeToInput converts a stored "YYYY-MM-DD HH:mm" to the
      // datetime-local input value ("YYYY-MM-DDTHH:mm").
      function recordTimeToInput(rt) {
        return rt && rt.length >= 16 ? rt.slice(0, 16).replace(' ', 'T') : localNowValue();
      }

      function openCreate() {
        editingId = null;
        document.getElementById('modal-title').textContent = '\u624b\u52a8\u8bb0\u8d26';
        fAmount.value = '';
        fRawType.value = '';
        fTime.value = localNowValue();
        fCategory.innerHTML = catOptions(null);
        fNote.value = '';
        modalMsg.textContent = '';
        showModal(modal);
        fAmount.focus();
      }

      function openEdit(id) {
        const e = rowCache.find(x => x.id === id);
        if (!e) return;
        editingId = id;
        document.getElementById('modal-title').textContent = '\u7f16\u8f91\u8d26\u76ee';
        fAmount.value = (e.amount_cents / 100).toFixed(2);
        fRawType.value = e.raw_type;
        fTime.value = recordTimeToInput(e.record_time);
        fCategory.innerHTML = catOptions(e.category_id);
        fNote.value = e.note || '';
        modalMsg.textContent = '';
        showModal(modal);
        fAmount.focus();
      }

      document.getElementById('btn-new').onclick = openCreate;
      document.getElementById('modal-close').onclick = () => hideModal(modal);
      document.getElementById('modal-cancel').onclick = () => hideModal(modal);

      document.getElementById('modal-save').onclick = async () => {
        const amount = parseFloat(fAmount.value);
        if (!(amount > 0)) { modalMsg.textContent = '\u91d1\u989d\u5fc5\u987b\u5927\u4e8e 0'; return; }
        if (!fRawType.value.trim() && !fCategory.value) { modalMsg.textContent = '\u6458\u8981\u548c\u5206\u7c7b\u81f3\u5c11\u586b\u4e00\u9879'; return; }
        if (!fTime.value) { modalMsg.textContent = '\u8bf7\u9009\u62e9\u65f6\u95f4'; return; }
        // datetime-local -> "YYYY-MM-DD HH:mm" (server normalizes anyway).
        const recordTime = fTime.value.replace('T', ' ');
        const body = {
          amount: String(amount),
          raw_type: fRawType.value.trim(),
          record_time: recordTime,
          note: fNote.value.trim(),
          category_id: fCategory.value ? Number(fCategory.value) : null,
        };
        const save = document.getElementById('modal-save');
        save.disabled = true;
        try {
          const url = editingId ? `/api/entries/${editingId}` : '/api/entries';
          const method = editingId ? 'PUT' : 'POST';
          const res = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (!res.ok) {
            const d = await res.json().catch(() => ({}));
            modalMsg.textContent = '\u274c ' + (d.error || '\u4fdd\u5b58\u5931\u8d25');
            return;
          }
          hideModal(modal);
          if (!editingId) offset = 0; // jump to newest page after create
          loadEntries();
        } finally {
          save.disabled = false;
        }
      };

      // ---- Delete ----
      const delModal = document.getElementById('del-modal');
      function openDelete(id) { deletingId = id; showModal(delModal); }
      document.getElementById('del-cancel').onclick = () => hideModal(delModal);
      document.getElementById('del-confirm').onclick = async () => {
        if (!deletingId) return;
        const btn = document.getElementById('del-confirm');
        btn.disabled = true;
        try {
          await fetch(`/api/entries/${deletingId}`, { method: 'DELETE' });
          hideModal(delModal);
          deletingId = null;
          loadEntries();
        } finally {
          btn.disabled = false;
        }
      };

      // Close modals on backdrop click.
      modal.onclick = (e) => { if (e.target === modal) hideModal(modal); };
      delModal.onclick = (e) => { if (e.target === delModal) hideModal(delModal); };

      // ---- CSV Import ----
      const importModal = document.getElementById('import-modal');
      const impStep1 = document.getElementById('import-step1');
      const impStep2 = document.getElementById('import-step2');
      const impMsg1 = document.getElementById('import-msg1');
      const impMsg2 = document.getElementById('import-msg2');
      const csvFile = document.getElementById('csv-file');
      let previewRows = [];

      function resetImport() {
        impStep1.hidden = false;
        impStep2.hidden = true;
        impMsg1.textContent = '';
        impMsg2.textContent = '';
        csvFile.value = '';
        previewRows = [];
      }
      function openImport() { resetImport(); showModal(importModal); if (window.lucide) lucide.createIcons(); }

      document.getElementById('btn-import').onclick = openImport;
      document.getElementById('import-close').onclick = () => hideModal(importModal);
      document.getElementById('import-back').onclick = () => resetImport();
      importModal.onclick = (e) => { if (e.target === importModal) hideModal(importModal); };
      document.getElementById('csv-pick').onclick = () => csvFile.click();

      csvFile.onchange = async () => {
        const file = csvFile.files && csvFile.files[0];
        if (!file) return;
        impMsg1.textContent = '解析中…';
        const fd = new FormData();
        fd.append('file', file);
        try {
          const res = await fetch('/api/import/csv', { method: 'POST', body: fd });
          const data = await res.json();
          if (!res.ok) { impMsg1.textContent = '❌ ' + (data.error || '解析失败'); return; }
          renderPreview(data);
        } catch (err) {
          impMsg1.textContent = '❌ 上传失败';
        }
      };

      function renderPreview(data) {
        previewRows = (data.sample_rows || []);
        document.getElementById('prev-total').textContent = data.total || 0;
        document.getElementById('prev-classified').textContent = data.classified || 0;
        document.getElementById('prev-unclassified').textContent = data.unclassified || 0;
        document.getElementById('prev-skipped').textContent = data.skipped || 0;
        document.getElementById('prev-income').textContent = fmtYuan(data.income_cents || 0);
        document.getElementById('prev-expense').textContent = fmtYuan(data.expense_cents || 0);
        document.getElementById('prev-unclass-amt').textContent = fmtYuan(data.unclassified_cents || 0);
        const box = document.getElementById('prev-sample');
        box.innerHTML = (data.sample_rows || []).map(r => {
          const cat = r.category_name ? `<span class="text-emerald-600">${r.category_name}</span>` : '<span class="text-amber-600">待分类</span>';
          return `<div class="flex justify-between gap-2 py-1 border-b border-slate-100"><span class="truncate">${r.record_time} · ${r.raw_type}</span><span class="shrink-0">${fmtYuan(Math.round(parseFloat(r.amount) * 100))} · ${cat}</span></div>`;
        }).join('') || '<p class="text-slate-400">无数据</p>';
        impStep1.hidden = true;
        impStep2.hidden = false;
      }

      document.getElementById('import-confirm').onclick = async () => {
        const file = csvFile.files && csvFile.files[0];
        if (!file) { impMsg2.textContent = '❌ 文件丢失，请重新选择'; return; }
        const btn = document.getElementById('import-confirm');
        btn.disabled = true;
        impMsg2.textContent = '导入中…';
        try {
          const fd = new FormData();
          fd.append('file', file);
          const cres = await fetch('/api/import/confirm', { method: 'POST', body: fd });
          const cdata = await cres.json();
          if (!cres.ok) { impMsg2.textContent = '❌ ' + (cdata.error || '导入失败'); return; }
          hideModal(importModal);
          loadEntries();
          alert(`导入完成：成功 ${cdata.imported} 条（已归类 ${cdata.classified} / 待分类 ${cdata.unclassified}），跳过 ${cdata.skipped} 条。`);
        } catch (err) {
          impMsg2.textContent = '❌ 导入失败';
        } finally {
          btn.disabled = false;
        }
      };
    </script>
  </body>
</html>
